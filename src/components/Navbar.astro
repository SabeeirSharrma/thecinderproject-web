---
// Navbar.astro
---

<header
  class="sticky top-0 z-50 w-full border-b border-border bg-base/80 backdrop-blur anim-slide-down"
>
  <div class="container mx-auto px-4 h-16 flex items-center justify-between">
    <div class="flex items-center gap-6">
      <a href="/" class="flex items-center gap-2 group">
        <span class="font-heading text-xl text-white tracking-widest uppercase group-hover:text-ember-core transition-colors duration-300"
          >The Cinder Project</span
        >
      </a>
    </div>
    <div class="flex items-center gap-4">
      <a
        href="https://thecinderproject.qd.je/"
        class="text-muted-text hover:text-white transition-colors duration-200">Home</a
      >
      <a
        href="https://discord.com/invite/3ZMtEgJjFT"
        target="_blank"
        rel="noopener noreferrer"
        class="text-muted-text hover:text-white transition-colors duration-200">Discord</a
      >
    </div>
  </div>
</header>
