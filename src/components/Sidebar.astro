---
import { getCollection } from 'astro:content';

export interface SidebarItem {
  title: string;
  sectionId: string;
  headings: { text: string; id: string }[];
}

export interface Props {
  project: string;
  sidebarData?: SidebarItem[];
}

const { project, sidebarData = [] } = Astro.props;
---

<aside class="sidebar" data-sidebar>
  <div class="sidebar-header">
    <div class="sidebar-icon">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path>
        <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path>
      </svg>
    </div>
    <h3>{project.toUpperCase()} Docs</h3>
  </div>
  
  <nav class="sidebar-nav">
    <ul>
      {sidebarData.map((item: SidebarItem) => (
        <li class="sidebar-topic" data-topic-id={item.sectionId}>
          <a 
            href={`#${item.sectionId}`}
            class="sidebar-link"
            data-section-target={item.sectionId}
          >
            <span class="link-indicator"></span>
            <span class="link-text">{item.title}</span>
            {item.headings.length > 0 && (
              <span class="expand-arrow">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="6 9 12 15 18 9"></polyline>
                </svg>
              </span>
            )}
          </a>
          {item.headings.length > 0 && (
            <ul class="sub-topics" data-subtopics-for={item.sectionId}>
              {item.headings.map((h) => (
                <li>
                  <a 
                    href={`#${h.id}`}
                    class="sub-topic-link"
                    data-subtopic-target={h.id}
                  >
                    <span class="sub-indicator"></span>
                    {h.text}
                  </a>
                </li>
              ))}
            </ul>
          )}
        </li>
      ))}
    </ul>
  </nav>

  <div class="sidebar-footer">
    <a href={`/${project}`} class="back-link">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="19" y1="12" x2="5" y2="12"></line>
        <polyline points="12 19 5 12 12 5"></polyline>
      </svg>
      Back to {project.toUpperCase()}
    </a>
  </div>
</aside>

<script>
  let activeSectionObserver: IntersectionObserver | null = null;
  let activeHeadingObserver: IntersectionObserver | null = null;

  function cleanupObservers() {
    if (activeSectionObserver) {
      activeSectionObserver.disconnect();
      activeSectionObserver = null;
    }
    if (activeHeadingObserver) {
      activeHeadingObserver.disconnect();
      activeHeadingObserver = null;
    }
  }

  function initSidebar() {
    cleanupObservers();

    const sidebar = document.querySelector('[data-sidebar]');
    if (!sidebar) return;

    const sections = document.querySelectorAll<HTMLElement>('.doc-section[data-section-id]');
    const topicLinks = sidebar.querySelectorAll<HTMLAnchorElement>('.sidebar-link[data-section-target]');
    const subTopicLinks = sidebar.querySelectorAll<HTMLAnchorElement>('.sub-topic-link[data-subtopic-target]');
    const allSubTopicLists = sidebar.querySelectorAll<HTMLUListElement>('.sub-topics');

    // Track which section is currently active
    let activeSection: string | null = null;
    let activeSubTopic: string | null = null;

    // Collapse all sub-topic lists
    function collapseAll() {
      allSubTopicLists.forEach(ul => {
        ul.classList.remove('expanded');
        ul.style.maxHeight = '0px';
      });
      topicLinks.forEach(link => link.classList.remove('active'));
      subTopicLinks.forEach(link => link.classList.remove('active'));

      // Reset expand arrows
      sidebar.querySelectorAll('.expand-arrow').forEach(arrow => {
        arrow.classList.remove('rotated');
      });
    }

    // Expand a specific section's sub-topics
    function expandSection(sectionId: string) {
      const ul = sidebar.querySelector<HTMLUListElement>(`[data-subtopics-for="${sectionId}"]`);
      const topicItem = sidebar.querySelector<HTMLElement>(`[data-topic-id="${sectionId}"]`);
      const link = sidebar.querySelector<HTMLAnchorElement>(`[data-section-target="${sectionId}"]`);

      if (link) {
        link.classList.add('active');
      }

      if (topicItem) {
        const arrow = topicItem.querySelector('.expand-arrow');
        if (arrow) arrow.classList.add('rotated');
      }

      if (ul) {
        ul.classList.add('expanded');
        // Calculate natural height for smooth animation
        ul.style.maxHeight = ul.scrollHeight + 'px';
      }
    }

    // Highlight a sub-topic
    function highlightSubTopic(headingId: string) {
      subTopicLinks.forEach(link => link.classList.remove('active'));
      const target = sidebar.querySelector<HTMLAnchorElement>(`[data-subtopic-target="${headingId}"]`);
      if (target) {
        target.classList.add('active');
      }
    }

    // --- IntersectionObserver for sections ---
    activeSectionObserver = new IntersectionObserver((entries) => {
      // Find the topmost visible section
      let topSection: { id: string; top: number } | null = null;
      
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const sectionId = (entry.target as HTMLElement).dataset.sectionId!;
          const rect = entry.boundingClientRect;
          if (!topSection || rect.top < topSection.top) {
            topSection = { id: sectionId, top: rect.top };
          }
        }
      });

      if (topSection) {
        const newSection = (topSection as { id: string; top: number }).id;
        if (newSection !== activeSection) {
          activeSection = newSection;
          collapseAll();
          expandSection(newSection);
        }
      }
    }, {
      threshold: 0,
      rootMargin: '-80px 0px -60% 0px'
    });

    sections.forEach(section => activeSectionObserver!.observe(section));

    // --- IntersectionObserver for h2 headings within sections ---
    const allH2s = document.querySelectorAll<HTMLElement>('.docs-body h2[id]');
    
    activeHeadingObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const headingId = entry.target.id;
          activeSubTopic = headingId;
          highlightSubTopic(headingId);
        }
      });
    }, {
      threshold: 0,
      rootMargin: '-80px 0px -70% 0px'
    });

    allH2s.forEach(h2 => activeHeadingObserver!.observe(h2));

    // --- Click handlers for smooth scrolling ---
    topicLinks.forEach(link => {
      link.addEventListener('click', (e) => {
        e.preventDefault();
        const targetId = link.dataset.sectionTarget!;
        const targetEl = document.getElementById(targetId);
        if (targetEl) {
          activeSection = targetId;
          collapseAll();
          expandSection(targetId);
          targetEl.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      });
    });

    subTopicLinks.forEach(link => {
      link.addEventListener('click', (e) => {
        e.preventDefault();
        const targetId = link.dataset.subtopicTarget!;
        const targetEl = document.getElementById(targetId);
        if (targetEl) {
          highlightSubTopic(targetId);
          targetEl.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      });
    });

    // Initialize: expand the first section
    if (sections.length > 0) {
      const firstId = (sections[0] as HTMLElement).dataset.sectionId!;
      activeSection = firstId;
      expandSection(firstId);
    }

    // Handle hash on load (e.g. direct link to #installation)
    if (window.location.hash) {
      const hash = window.location.hash.slice(1);
      const targetEl = document.getElementById(hash);
      if (targetEl) {
        setTimeout(() => {
          targetEl.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }, 100);
      }
    }
  }

  // Run on initial load
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initSidebar);
  } else {
    initSidebar();
  }

  // Re-run after Astro page transitions
  document.addEventListener('astro:page-load', initSidebar);
</script>

<style>
  .sidebar {
    width: 260px;
    flex-shrink: 0;
    position: sticky;
    top: 5rem;
    align-self: flex-start;
    max-height: calc(100vh - 6rem);
    overflow-y: auto;
    display: none;
    flex-direction: column;
    gap: 1.5rem;
    padding-right: 1.5rem;
    border-right: 1px solid var(--color-border);
  }

  @media (min-width: 768px) {
    .sidebar {
      display: flex;
    }
  }

  .sidebar-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--color-border);
  }

  .sidebar-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    background: var(--color-cinder-dark);
    border-radius: 8px;
    color: var(--color-ember-core);
  }

  .sidebar-header h3 {
    font-family: var(--font-heading);
    font-size: 1rem;
    color: var(--color-primary-text);
    letter-spacing: 0.15em;
    margin: 0;
  }

  .sidebar-nav ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  /* Topic link */
  .sidebar-link {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.6rem 0.75rem;
    border-radius: 8px;
    color: var(--color-muted-text);
    text-decoration: none;
    font-size: 0.875rem;
    transition: all 0.2s ease;
    position: relative;
    cursor: pointer;
  }

  .sidebar-link .link-text {
    flex: 1;
  }

  .sidebar-link:hover {
    background: var(--color-surface);
    color: var(--color-primary-text);
  }

  .sidebar-link.active {
    background: var(--color-cinder-dark);
    color: var(--color-ember-light);
    font-weight: 600;
  }

  .link-indicator {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-border);
    flex-shrink: 0;
    transition: all 0.2s ease;
  }

  .sidebar-link:hover .link-indicator {
    background: var(--color-ember-core);
    box-shadow: 0 0 8px var(--color-ember-core);
  }

  .sidebar-link.active .link-indicator {
    background: var(--color-ember-core);
    box-shadow: 0 0 10px var(--color-ember-core);
  }

  /* Expand arrow */
  .expand-arrow {
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    opacity: 0.5;
    flex-shrink: 0;
  }

  .expand-arrow.rotated {
    transform: rotate(180deg);
    opacity: 1;
  }

  .sidebar-link.active .expand-arrow {
    opacity: 1;
    color: var(--color-ember-light);
  }

  /* Sub-topics */
  .sub-topics {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.35s cubic-bezier(0.4, 0, 0.2, 1),
                opacity 0.25s ease;
    opacity: 0;
    padding-left: 1.25rem;
    margin-left: 0.75rem;
    border-left: 1px solid var(--color-border);
  }

  .sub-topics.expanded {
    opacity: 1;
  }

  .sub-topic-link {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.35rem 0.6rem;
    border-radius: 6px;
    color: var(--color-muted-text);
    text-decoration: none;
    font-size: 0.8rem;
    transition: all 0.2s ease;
    cursor: pointer;
  }

  .sub-topic-link:hover {
    background: var(--color-surface);
    color: var(--color-primary-text);
  }

  .sub-topic-link.active {
    color: var(--color-ember-light);
    background: rgba(255, 69, 0, 0.08);
  }

  .sub-indicator {
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--color-border);
    flex-shrink: 0;
    transition: all 0.2s ease;
  }

  .sub-topic-link:hover .sub-indicator {
    background: var(--color-ember-core);
  }

  .sub-topic-link.active .sub-indicator {
    background: var(--color-ember-core);
    box-shadow: 0 0 6px var(--color-ember-core);
  }

  /* Footer */
  .sidebar-footer {
    margin-top: auto;
    padding-top: 1rem;
    border-top: 1px solid var(--color-border);
  }

  .back-link {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-muted-text);
    text-decoration: none;
    font-size: 0.8rem;
    transition: color 0.2s ease;
  }

  .back-link:hover {
    color: var(--color-ember-light);
  }
</style>
