---
// Footer.astro
const year = new Date().getFullYear();
---

<footer class="border-t border-border bg-base mt-20">
  <div class="container mx-auto px-4 py-12">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8 reveal">
      <div class="col-span-1 md:col-span-2">
        <h3
          class="font-heading text-xl text-white tracking-widest uppercase mb-4"
        >
          The Cinder Project
        </h3>
        <p class="text-muted-text max-w-sm">
          Burn All the Blind Spots. We develop and maintain open-source
          software with a focus on transparency, trust, security, stability, and long-term
          maintainability.
        </p>
      </div>
      <div>
        <h4 class="font-heading text-lg text-white mb-4">Projects</h4>
        <ul class="space-y-2">
          <li>
            <a
              href="/cpac"
              class="text-muted-text hover:text-ember-light transition-colors"
              >CPAC</a>
          </li>
          <li>
            <a
              href="/cpac-trust-db"
              class="text-muted-text hover:text-ember-light transition-colors"
              >CPAC Trust DB</a>
          </li>
        </ul>
      </div>
      <div>
        <h4 class="font-heading text-lg text-white mb-4">Community</h4>
        <ul class="space-y-2">
          <li>
            <a
              href="https://thecinderproject.qd.je/"
              class="text-muted-text hover:text-ember-light transition-colors"
              >Home</a>
          </li>
          <li>
            <a
              href="https://discord.com/invite/3ZMtEgJjFT"
              class="text-muted-text hover:text-ember-light transition-colors"
              >Discord</a>
          </li>
          <li>
            <a
              href="/donate"
              class="text-muted-text hover:text-ember-light transition-colors"
              >Donate</a>
          </li>
        </ul>
      </div>
    </div>
    <div
      class="mt-12 pt-8 border-t border-border flex flex-col md:flex-row items-center justify-between"
    >
      <p class="text-muted-text text-sm">
        &copy; {year} The Cinder Project. All rights reserved.
      </p>
    </div>
  </div>
</footer>
