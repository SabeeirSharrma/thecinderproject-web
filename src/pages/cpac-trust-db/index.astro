---
import MainLayout from '../../layouts/MainLayout.astro';
---

<MainLayout title="CPAC">
  <div class="container mx-auto px-4 py-16 max-w-4xl">
    
    <!-- Header -->
    <header class="mb-16 border-b border-border pb-8">
      <h1 class="text-5xl md:text-6xl font-heading text-white mb-4 uppercase tracking-widest anim-slide-up">CPAC Trust DB</h1>
      <p class="text-2xl text-ember-core font-heading tracking-wide anim-slide-up delay-2">Community-maintained trust data for <a href="/cpac">CPAC</a></p>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
      
      <!-- Main Content Area -->
      <div class="md:col-span-2 space-y-12">
        
        <!-- Overview -->
        <section class="reveal">
          <h2 class="text-2xl font-heading text-white mb-4 uppercase tracking-widest heading-line">Overview</h2>
          <div class="prose prose-invert prose-cinder">
            <p>
            cpac-trust-db is the trust data backend for CPAC. It stores two categories of data:
            <ol>
                <li>PKGBUILD snapshots — anonymized, crowdsourced snapshots submitted by CPAC clients, used to detect divergence from known-good package states</li>
                <li> Maintainer-curated records of known malicious, compromised, or suspicious packages (e.g. Atomic Arch-style hijacks)</li>
            </ol>
            </p>
          </div>
        </section>

        <!-- Current Status -->
        <section class="reveal stagger-1">
          <h2 class="text-2xl font-heading text-white mb-4 uppercase tracking-widest heading-line">Current Status</h2>
          <div class="bg-surface p-6 rounded-lg border border-border">
            <div class="flex items-center gap-4 mb-4">
              <span class="w-3 h-3 rounded-full bg-ember-core animate-pulse"></span>
              <span class="text-white font-bold tracking-wider">Active Development</span>
            </div>
            <p class="text-muted-text">
              CPAC is currently in active development. Core package resolution algorithms are being refined, and the CLI interface is stabilizing.
            </p>
          </div>
        </section>

        <!-- Recent Updates -->
        <section class="reveal stagger-2">
          <h2 class="text-2xl font-heading text-white mb-4 uppercase tracking-widest heading-line">Recent Updates</h2>
          <ul class="space-y-4">
            <li class="border-l-2 border-cinder-mid pl-4 py-1">
              <span class="text-sm text-ember-light font-bold mb-1 block">June 2026</span>
              <p class="text-muted-text">Initial routing and documentation structure established.</p>
            </li>
            <li class="border-l-2 border-cinder-mid pl-4 py-1">
              <span class="text-sm text-ember-light font-bold mb-1 block">May 2026</span>
              <p class="text-muted-text">Core dependency resolution algorithm prototype completed.</p>
            </li>
          </ul>
        </section>

      </div>

      <!-- Sidebar Area -->
      <aside class="space-y-8 reveal-right stagger-2">
        
        <!-- Quick Links -->
        <div class="bg-card p-6 rounded-lg border border-border">
          <h3 class="text-xl font-heading text-white mb-4 uppercase tracking-widest">Quick Links</h3>
          <ul class="space-y-3">
            <li>
              <a href="/cpac-trust-db/docs" class="flex items-center gap-2 text-muted-text hover:text-ember-light transition-colors group">
                <span class="text-cinder-mid group-hover:text-ember-core transition-colors">▶</span> Documentation
              </a>
            </li>
            <li>
              <a href="https://github.com/SabeeirSharrma/cpac-trust-db" class="flex items-center gap-2 text-muted-text hover:text-ember-light transition-colors group">
                <span class="text-cinder-mid group-hover:text-ember-core transition-colors">▶</span> Source Code
              </a>
            </li>
            <li>
              <a href="/cpac-trust-db/web" class="flex items-center gap-2 text-muted-text hover:text-ember-light transition-colors group">
                <span class="text-cinder-mid group-hover:text-ember-core transition-colors">▶</span> Web UI
              </a>
            </li>
          </ul>
        </div>
        
      </aside>

    </div>
  </div>
</MainLayout>
