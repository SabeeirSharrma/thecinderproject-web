---
import MainLayout from '../../../layouts/MainLayout.astro';
---

<MainLayout title="Trust Database" description="Live view of the CPAC trust database — advisories, snapshots, and metadata.">
  <div class="container mx-auto px-4 py-16 max-w-6xl">
    
    <!-- Header -->
    <header class="mb-12 border-b border-border pb-8">
      <h1 class="text-5xl md:text-6xl font-heading text-white mb-4 uppercase tracking-widest anim-slide-up">Trust Database</h1>
      <p class="text-2xl text-ember-core font-heading tracking-wide anim-slide-up delay-2">Live data from cpac-trust-db</p>
    </header>

    <!-- Stats Bar -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-12">
      <div class="bg-surface p-4 rounded-lg border border-border text-center">
        <div class="text-3xl font-heading text-ember-core" id="stat-advisories">—</div>
        <div class="text-sm text-muted-text uppercase tracking-wider">Advisories</div>
      </div>
      <div class="bg-surface p-4 rounded-lg border border-border text-center">
        <div class="text-3xl font-heading text-ember-core" id="stat-snapshots">—</div>
        <div class="text-sm text-muted-text uppercase tracking-wider">Snapshots</div>
      </div>
      <div class="bg-surface p-4 rounded-lg border border-border text-center">
        <div class="text-3xl font-heading text-ember-core" id="stat-version">—</div>
        <div class="text-sm text-muted-text uppercase tracking-wider">DB Version</div>
      </div>
      <div class="bg-surface p-4 rounded-lg border border-border text-center">
        <div class="text-3xl font-heading text-ember-core" id="stat-updated">—</div>
        <div class="text-sm text-muted-text uppercase tracking-wider">Last Updated</div>
      </div>
    </div>

    <!-- Tab Navigation -->
    <div class="flex gap-1 mb-8 border-b border-border">
      <button id="tab-advisories" class="tab-btn active" onclick="showTab('advisories')">
        Advisories
      </button>
      <button id="tab-snapshots" class="tab-btn" onclick="showTab('snapshots')">
        Snapshots
      </button>
      <button id="tab-about" class="tab-btn" onclick="showTab('about')">
        About
      </button>
    </div>

    <!-- Advisories Tab -->
    <div id="panel-advisories" class="tab-panel">
      <div id="advisories-loading" class="text-center py-12 text-muted-text">
        Loading advisories...
      </div>
      <div id="advisories-empty" class="hidden text-center py-12">
        <div class="text-6xl mb-4 opacity-30">✓</div>
        <p class="text-xl text-muted-text">No active advisories</p>
        <p class="text-sm text-muted-text mt-2">The database is clean — no known compromised packages.</p>
      </div>
      <div id="advisories-list" class="space-y-4"></div>
    </div>

    <!-- Snapshots Tab -->
    <div id="panel-snapshots" class="tab-panel hidden">
      <div id="snapshots-loading" class="text-center py-12 text-muted-text">
        Loading snapshots...
      </div>
      <div id="snapshots-empty" class="hidden text-center py-12">
        <div class="text-6xl mb-4 opacity-30">📦</div>
        <p class="text-xl text-muted-text">No snapshots yet</p>
        <p class="text-sm text-muted-text mt-2">CPAC clients will submit anonymized PKGBUILD hashes as they install packages.</p>
      </div>
      <div id="snapshots-list" class="space-y-4"></div>
    </div>

    <!-- About Tab -->
    <div id="panel-about" class="tab-panel hidden">
      <div class="prose prose-invert prose-cinder max-w-3xl space-y-6">
        <h2 class="text-2xl font-heading text-white">What is this?</h2>
        <p class="text-muted-text">
          This page shows the live contents of the <strong class="text-white">CPAC Trust Database</strong> — 
          the community-maintained trust data backend for <a href="/cpac" class="text-ember-light hover:text-ember-core transition-colors">CPAC</a>.
        </p>
        
        <h2 class="text-2xl font-heading text-white">Data Categories</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div class="bg-surface p-4 rounded-lg border border-border">
            <h3 class="font-heading text-white mb-2">Advisories</h3>
            <p class="text-sm text-muted-text">Maintainer-curated records of known malicious, compromised, or suspicious packages. Only the core team can publish advisories.</p>
          </div>
          <div class="bg-surface p-4 rounded-lg border border-border">
            <h3 class="font-heading text-white mb-2">Snapshots</h3>
            <p class="text-sm text-muted-text">Anonymized, crowdsourced PKGBUILD hashes submitted by CPAC clients. Used to detect divergence from known-good package states.</p>
          </div>
        </div>

        <h2 class="text-2xl font-heading text-white">How It Works</h2>
        <ol class="list-decimal list-inside space-y-2 text-muted-text">
          <li>CPAC clients check advisories before installing packages</li>
          <li>Known malicious packages receive trust score penalties</li>
          <li>Crowdsourced snapshots detect tampered PKGBUILDs</li>
          <li>Data is synced nightly from Supabase to the GitHub repo</li>
        </ol>

        <h2 class="text-2xl font-heading text-white">Source Code</h2>
        <p class="text-muted-text">
          The full database is open source on 
          <a href="https://github.com/SabeeirSharrma/cpac-trust-db" class="text-ember-light hover:text-ember-core transition-colors">GitHub</a>. 
          Every change is auditable via git history.
        </p>
      </div>
    </div>

  </div>

  <style>
    .tab-btn {
      padding: 0.75rem 1.5rem;
      font-family: var(--font-heading);
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      font-size: 0.875rem;
      color: var(--color-muted-text);
      border-bottom: 2px solid transparent;
      transition: all 0.2s;
      cursor: pointer;
      background: none;
      border-top: none;
      border-left: none;
      border-right: none;
    }
    .tab-btn:hover {
      color: var(--color-ember-light);
    }
    .tab-btn.active {
      color: var(--color-ember-core);
      border-bottom-color: var(--color-ember-core);
    }
    .advisory-card {
      background: var(--color-surface);
      border: 1px solid var(--color-border);
      border-radius: 0.5rem;
      padding: 1.5rem;
      transition: border-color 0.2s;
    }
    .advisory-card:hover {
      border-color: var(--color-cinder-mid);
    }
    .severity-badge {
      display: inline-block;
      padding: 0.125rem 0.5rem;
      border-radius: 9999px;
      font-size: 0.75rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }
    .severity-critical { background: #7f1d1d; color: #fca5a5; }
    .severity-high { background: #92400e; color: #fcd34d; }
    .severity-medium { background: #713f12; color: #fde68a; }
    .severity-low { background: #1e3a5f; color: #93c5fd; }
    .status-badge {
      display: inline-block;
      padding: 0.125rem 0.5rem;
      border-radius: 9999px;
      font-size: 0.75rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }
    .status-confirmed { background: #7f1d1d; color: #fca5a5; }
    .status-suspected { background: #713f12; color: #fde68a; }
    .status-resolved { background: #14532d; color: #86efac; }
    .snapshot-row {
      display: grid;
      grid-template-columns: 1fr auto auto auto;
      gap: 1rem;
      align-items: center;
      padding: 0.75rem 1rem;
      background: var(--color-surface);
      border: 1px solid var(--color-border);
      border-radius: 0.5rem;
      font-size: 0.875rem;
    }
    .hash-text {
      font-family: monospace;
      font-size: 0.75rem;
      color: var(--color-muted-text);
      overflow: hidden;
      text-overflow: ellipsis;
    }
  </style>

  <script is:inline>
    const SUPABASE_URL = 'https://qzhhsyucnlswmsvpssdh.supabase.co';
    const SUPABASE_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InF6aGhzeXVjbmxzd21zdnBzc2RoIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODI0NzE1NDQsImV4cCI6MjA5ODA0NzU0NH0.sIQobt0xfnMsgthGLJUb1S8f1yisDcavtRoWzi7y4OA';

    const headers = {
      'apikey': SUPABASE_KEY,
      'Authorization': `Bearer ${SUPABASE_KEY}`,
    };

    function showTab(name) {
      document.querySelectorAll('.tab-panel').forEach(p => p.classList.add('hidden'));
      document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
      document.getElementById(`panel-${name}`).classList.remove('hidden');
      document.getElementById(`tab-${name}`).classList.add('active');
    }

    function severityBadge(s) {
      return `<span class="severity-badge severity-${s}">${s}</span>`;
    }

    function statusBadge(s) {
      return `<span class="status-badge status-${s}">${s}</span>`;
    }

    function timeAgo(dateStr) {
      const d = new Date(dateStr);
      const now = new Date();
      const diff = Math.floor((now - d) / 1000);
      if (diff < 60) return 'just now';
      if (diff < 3600) return `${Math.floor(diff/60)}m ago`;
      if (diff < 86400) return `${Math.floor(diff/3600)}h ago`;
      if (diff < 2592000) return `${Math.floor(diff/86400)}d ago`;
      return d.toLocaleDateString();
    }

    async function loadAdvisories() {
      try {
        const res = await fetch(`${SUPABASE_URL}/rest/v1/advisories?select=*&order=reported.desc`, { headers });
        const data = await res.json();
        
        document.getElementById('stat-advisories').textContent = data.length;
        document.getElementById('advisories-loading').classList.add('hidden');

        if (data.length === 0) {
          document.getElementById('advisories-empty').classList.remove('hidden');
          return;
        }

        const container = document.getElementById('advisories-list');
        container.innerHTML = data.map(a => `
          <div class="advisory-card">
            <div class="flex flex-wrap items-center gap-3 mb-3">
              <h3 class="text-lg font-heading text-white">${a.package}</h3>
              ${severityBadge(a.severity)}
              ${statusBadge(a.status)}
            </div>
            <p class="text-muted-text mb-3">${a.summary}</p>
            <div class="flex flex-wrap gap-x-6 gap-y-1 text-sm text-muted-text">
              <span>Reported: <strong class="text-white">${a.reported}</strong></span>
              <span>By: <strong class="text-white">${a.reported_by}</strong></span>
              ${a.cve ? `<span>CVE: <strong class="text-white">${a.cve}</strong></span>` : ''}
            </div>
            ${a.affected_versions && a.affected_versions.length > 0 ? `
              <div class="mt-3 text-sm">
                <span class="text-muted-text">Affected:</span>
                <span class="text-white">${a.affected_versions.join(', ')}</span>
              </div>
            ` : ''}
            ${a.safe_versions && a.safe_versions.length > 0 ? `
              <div class="mt-1 text-sm">
                <span class="text-muted-text">Safe:</span>
                <span class="text-white">${a.safe_versions.join(', ')}</span>
              </div>
            ` : ''}
            ${a.description ? `
              <details class="mt-3">
                <summary class="text-sm text-ember-light cursor-pointer hover:text-ember-core transition-colors">Show details</summary>
                <p class="mt-2 text-sm text-muted-text whitespace-pre-line">${a.description}</p>
              </details>
            ` : ''}
          </div>
        `).join('');
      } catch (e) {
        document.getElementById('advisories-loading').textContent = 'Failed to load advisories.';
        console.error(e);
      }
    }

    async function loadSnapshots() {
      try {
        const res = await fetch(`${SUPABASE_URL}/rest/v1/snapshots?select=*&order=package,version`, { headers });
        const data = await res.json();
        
        document.getElementById('stat-snapshots').textContent = data.length;
        document.getElementById('snapshots-loading').classList.add('hidden');

        if (data.length === 0) {
          document.getElementById('snapshots-empty').classList.remove('hidden');
          return;
        }

        const container = document.getElementById('snapshots-list');
        container.innerHTML = data.map(s => `
          <div class="snapshot-row">
            <div>
              <span class="text-white font-bold">${s.package}</span>
              <span class="text-muted-text ml-2">${s.version}</span>
            </div>
            <div class="hash-text" title="${s.sha256}">${s.sha256.substring(0, 16)}...</div>
            <div class="text-muted-text">${s.submitted_count} submissions</div>
            <div class="text-muted-text text-sm">${timeAgo(s.last_seen)}</div>
          </div>
        `).join('');
      } catch (e) {
        document.getElementById('snapshots-loading').textContent = 'Failed to load snapshots.';
        console.error(e);
      }
    }

    async function loadMeta() {
      try {
        const res = await fetch(`${SUPABASE_URL}/rest/v1/advisories?select=updated&order=updated.desc&limit=1`, { headers });
        const data = await res.json();
        
        if (data.length > 0) {
          document.getElementById('stat-updated').textContent = timeAgo(data[0].updated);
        } else {
          document.getElementById('stat-updated').textContent = 'N/A';
        }

        // Version is a hash, show first 8 chars
        document.getElementById('stat-version').textContent = 'live';
      } catch (e) {
        document.getElementById('stat-updated').textContent = 'N/A';
        document.getElementById('stat-version').textContent = 'N/A';
      }
    }

    // Load everything
    loadAdvisories();
    loadSnapshots();
    loadMeta();

    // Auto-refresh every 5 minutes
    setInterval(() => {
      loadAdvisories();
      loadSnapshots();
      loadMeta();
    }, 300000);
  </script>
</MainLayout>
