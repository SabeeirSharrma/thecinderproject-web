          var advs = await advRes.json();
          var advMap = {}; advs.forEach(function(a) { advMap[a.package] = a; });
          var pkgMap = {};
          snaps.forEach(function(s) { if (!pkgMap[s.package]) pkgMap[s.package] = { name: s.package, latestVersion: s.version, latestDate: s.created_at, hasAdvisory: false, advisoryVersion: null }; });
          Object.keys(advMap).forEach(function(pkg) { if (pkgMap[pkg]) { pkgMap[pkg].hasAdvisory = true; pkgMap[pkg].advisoryVersion = advMap[pkg].version; } });
          allPackages = Object.values(pkgMap).filter(function(p) { return !p.hasAdvisory || p.advisoryVersion !== p.latestVersion; })
            .map(function(p) { return { name: p.name, latestVersion: p.latestVersion, latestDate: p.latestDate, status: p.hasAdvisory ? 'stale' : 'none' }; })
            .sort(function(a, b) { return a.name.localeCompare(b.name); });
