      // ══════════════════════════════════════════════
      //  AUTOMATED COMPARE
      // ══════════════════════════════════════════════
      async function runAutoCompare(pkgName) {
        var loading = document.getElementById('auto-compare-loading');
        var loadingSplit = document.getElementById('auto-compare-loading-split');
        var error = document.getElementById('auto-compare-error');
        var errorSplit = document.getElementById('auto-compare-error-split');
        var result = document.getElementById('compare-result');
        var resultSplit = document.getElementById('compare-result-split');
        var controls = document.getElementById('manual-controls');
        var controlsSplit = document.getElementById('manual-controls-split');
        if (currentLayout === 'tabs') { loading.classList.remove('hidden'); error.classList.add('hidden'); result.classList.add('hidden'); controls.classList.add('hidden'); }
        else { loadingSplit.classList.remove('hidden'); errorSplit.classList.add('hidden'); resultSplit.classList.add('hidden'); controlsSplit.classList.add('hidden'); }
        try {
          var snapRes = await fetch(SUPABASE_URL + '/rest/v1/snapshots?select=*&package=eq.' + encodeURIComponent(pkgName) + '&order=version.desc', { headers: anonHeaders() });
          currentSnapshots = await snapRes.json();
          var aurRes = await fetch(API_PREFIX + '/aur/info/' + encodeURIComponent(pkgName));
          var aurData = await aurRes.json();
          if (aurData.resultcount === 0 && currentSnapshots.length === 0) { var errEl = currentLayout === 'tabs' ? error : errorSplit; errEl.textContent = 'Package not found.'; errEl.classList.remove('hidden'); if (currentLayout === 'tabs') loading.classList.add('hidden'); else loadingSplit.classList.add('hidden'); return; }
          currentPkgData = { name: pkgName, aurInfo: aurData.resultcount > 0 ? aurData.results[0] : null, snapshots: currentSnapshots, versions: [...new Set(currentSnapshots.map(function(s) { return s.version; }))] };
          if (currentPkgData.aurInfo && currentPkgData.versions.indexOf(currentPkgData.aurInfo.Version) === -1) currentPkgData.versions.push(currentPkgData.aurInfo.Version);
          currentPkgData.versions.sort();
          if (currentPkgData.versions.length < 2) { var errEl2 = currentLayout === 'tabs' ? error : errorSplit; errEl2.textContent = 'Only one version.'; errEl2.classList.remove('hidden'); if (currentLayout === 'tabs') loading.classList.add('hidden'); else loadingSplit.classList.add('hidden'); return; }
          var vOld = currentPkgData.versions[currentPkgData.versions.length - 2];
          var vNew = currentPkgData.versions[currentPkgData.versions.length - 1];
          var oldText = await fetchPkgbuild(pkgName, vOld, currentPkgData);
          var newText = await fetchPkgbuild(pkgName, vNew, currentPkgData);
          if (!oldText && !newText) { var errEl3 = currentLayout === 'tabs' ? error : errorSplit; errEl3.textContent = 'Could not fetch PKGBUILDs.'; errEl3.classList.remove('hidden'); if (currentLayout === 'tabs') loading.classList.add('hidden'); else loadingSplit.classList.add('hidden'); return; }
          var diff = computeDiff(oldText || '', newText || '', vOld, vNew);
          var suspicious = detectSuspicious(newText || '');
          var advRes2 = await fetch(SUPABASE_URL + '/rest/v1/advisories?select=*&package=eq.' + encodeURIComponent(pkgName), { headers: anonHeaders() });
          var advisories = await advRes2.json();
          var advisory = advisories.length > 0 ? advisories[0] : null;
          var html = buildDiffHtml(diff, suspicious, advisory, { pkg: pkgName, vOld: vOld, vNew: vNew, oldText: oldText, newText: newText });
          if (currentLayout === 'tabs') { result.innerHTML = html; result.classList.remove('hidden'); controls.classList.remove('hidden'); loading.classList.add('hidden'); }
          else { resultSplit.innerHTML = html; resultSplit.classList.remove('hidden'); controlsSplit.classList.remove('hidden'); loadingSplit.classList.add('hidden'); }
        } catch(e) { var errEl4 = currentLayout === 'tabs' ? error : errorSplit; errEl4.textContent = 'Error: ' + e.message; errEl4.classList.remove('hidden'); if (currentLayout === 'tabs') loading.classList.add('hidden'); else loadingSplit.classList.add('hidden'); }
      }

      // ══════════════════════════════════════════════
      //  SHARED DIFF LOGIC
      // ══════════════════════════════════════════════
      async function fetchPkgbuild(pkg, version, data) {
        var snap = data.snapshots.find(function(s) { return s.version === version && s.pkgbuild_text; });
        if (snap && snap.pkgbuild_text) return snap.pkgbuild_text;
        if (data.aurInfo && data.aurInfo.Version === version) { try { var res = await fetch(API_PREFIX + '/aur/pkgbuild/' + encodeURIComponent(pkg)); var text = await res.text(); if (text && text.length > 10 && text.indexOf('#') !== -1) return text; } catch(e) {} }
        return null;
      }
      function computeDiff(oldText, newText) {
        var o = oldText.split('\n'), n = newText.split('\n');
        var result = { lines: [], stats: { added: 0, removed: 0, unchanged: 0 } };
        var m = o.length, k = n.length;
        var dp = Array.from({ length: m + 1 }, function() { return new Array(k + 1).fill(0); });
        for (var i = 1; i <= m; i++) for (var j = 1; j <= k; j++) dp[i][j] = o[i-1] === n[j-1] ? dp[i-1][j-1] + 1 : Math.max(dp[i-1][j], dp[i][j-1]);
        var ii = m, jj = k, raw = [];
        while (ii > 0 || jj > 0) { if (ii > 0 && jj > 0 && o[ii-1] === n[jj-1]) { raw.unshift({ type: 'ctx', text: o[ii-1] }); result.stats.unchanged++; ii--; jj--; } else if (jj > 0 && (ii === 0 || dp[ii][jj-1] >= dp[ii-1][jj])) { raw.unshift({ type: 'add', text: n[jj-1] }); result.stats.added++; jj--; } else { raw.unshift({ type: 'del', text: o[ii-1] }); result.stats.removed++; ii--; } }
        result.lines = raw; return result;
      }
      var SUSPICIOUS_PATTERNS = [
        { re: /curl\s+.*\|\s*(bash|sh)/i, label: 'curl pipe to shell', severity: 'high' },
        { re: /wget\s+.*\|\s*(sh|bash)/i, label: 'wget pipe to shell', severity: 'high' },
        { re: /\beval\b/i, label: 'eval usage', severity: 'high' },
        { re: /rm\s+-rf\s+[\/~]/i, label: 'Aggressive rm -rf', severity: 'high' },
        { re: /npm\s+install\s+.*\|\s*(bash|sh|node)/i, label: 'npm pipe to shell', severity: 'high' },
        { re: /npx\s+.*\|\s*(bash|sh)/i, label: 'npx pipe to shell', severity: 'high' },
        { re: /\\x[0-9a-f]{2}/i, label: 'Hex escape', severity: 'medium' },
        { re: /\bbase64\s+-d/i, label: 'Base64 decode', severity: 'medium' },
      ];
      function detectSuspicious(text) { var f = []; text.split('\n').forEach(function(line, idx) { SUSPICIOUS_PATTERNS.forEach(function(p) { if (p.re.test(line)) f.push({ line: idx + 1, label: p.label, severity: p.severity }); }); }); return f; }
      function buildDiffHtml(diff, suspicious, advisory, ctx) {
        var identical = diff.stats.added === 0 && diff.stats.removed === 0;
        var html = '<div class="bg-surface border border-border rounded-xl p-6">';
        html += '<div class="flex flex-wrap items-center gap-3 mb-4"><h3 class="text-xl font-heading text-white">' + ctx.pkg + '</h3>';
        html += identical ? '<span class="verdict-badge verdict-clean">IDENTICAL</span>' : suspicious.length > 0 ? '<span class="verdict-badge verdict-advisory">CHANGES</span>' : '<span class="verdict-badge verdict-outdated">MODIFIED</span>';
        html += '</div>';
        html += '<div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-4 text-sm">';
        html += '<div><span class="text-muted-text">Old:</span> <span class="text-white">' + ctx.vOld + '</span></div>';
        html += '<div><span class="text-muted-text">New:</span> <span class="text-white">' + ctx.vNew + '</span></div>';
        html += '<div><span class="text-muted-text">Added:</span> <span class="text-green-400">+' + diff.stats.added + '</span></div>';
        html += '<div><span class="text-muted-text">Removed:</span> <span class="text-red-400">-' + diff.stats.removed + '</span></div></div>';
        if (advisory) html += '<div class="bg-red-900/20 border border-red-800 rounded-lg p-3 text-sm mb-4"><span class="text-red-400 font-bold">Advisory:</span> ' + advisory.severity.toUpperCase() + ' — ' + advisory.summary + '</div>';
        if (suspicious.length > 0) { html += '<div class="bg-yellow-900/20 border border-yellow-800 rounded-lg p-3 text-sm mb-4"><span class="text-yellow-400 font-bold">Suspicious (' + suspicious.length + '):</span><ul class="mt-1">'; suspicious.forEach(function(s) { html += '<li class="text-xs">[' + s.severity.toUpperCase() + '] Line ' + s.line + ': ' + s.label + '</li>'; }); html += '</ul></div>'; }
        if (!identical) { html += '<div class="border border-border rounded-lg overflow-hidden"><div class="diff-hunk">@@ Diff: ' + ctx.vOld + ' → ' + ctx.vNew + ' @@</div>'; diff.lines.forEach(function(line) { if (line.type === 'ctx') return; html += '<div class="diff-line ' + (line.type === 'add' ? 'diff-add' : 'diff-del') + '">' + (line.type === 'add' ? '+' : '-') + ' ' + line.text.replace(/</g,'&lt;') + '</div>'; }); html += '</div>'; }
        else { html += '<div class="text-center py-6 text-muted-text text-sm">Identical.</div>'; }
        html += '</div>'; return html;
      }
      window.runManualCompare = function() { if (selectedPkg) runAutoCompare(selectedPkg); };

      // ══════════════════════════════════════════════
      //  AI ANALYSIS
      // ══════════════════════════════════════════════
      async function runAiAnalysisBase(resultElId) {
        if (!currentPkgData || !selectedPkg) return;
        var vOld = currentPkgData.versions[currentPkgData.versions.length - 2];
        var vNew = currentPkgData.versions[currentPkgData.versions.length - 1];
        var resultEl = document.getElementById(resultElId);
        var oldText = await fetchPkgbuild(selectedPkg, vOld, currentPkgData);
        var newText = await fetchPkgbuild(selectedPkg, vNew, currentPkgData);
        resultEl.classList.remove('hidden');
        resultEl.innerHTML = '<div class="text-muted-text text-sm">Checking AI cache...</div>';
        try {
          var diffHash = await sha256((oldText || '') + '---' + (newText || ''));
          var cacheRes = await fetch(SUPABASE_URL + '/rest/v1/ai_analysis?select=*&package=eq.' + encodeURIComponent(selectedPkg) + '&version_old=eq.' + encodeURIComponent(vOld) + '&version_new=eq.' + encodeURIComponent(vNew) + '&diff_hash=eq.' + diffHash + '&expires_at=gt.' + new Date().toISOString(), { headers: anonHeaders() });
          var cached = await cacheRes.json();
          if (cached && cached.length > 0) { var parsed = cached[0].analysis; try { parsed = JSON.parse(parsed); } catch(e) {} renderAiResult(resultEl, parsed, cached[0].recommendation, true); return; }
          resultEl.innerHTML = '<div class="text-muted-text text-sm">Running AI analysis via NVIDIA NIM...</div>';
          var suspicious = detectSuspicious(newText || '');
          var aiRes = await fetch(WORKER_URL + '/cpac-trust-db/api/ai/analyze-diff', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ package: selectedPkg, version_old: vOld, version_new: vNew, old_pkgbuild: oldText || '', new_pkgbuild: newText || '', suspicious_patterns: suspicious }) });
          if (!aiRes.ok) { var errData = await aiRes.json().catch(function() { return { error: 'AI request failed' }; }); resultEl.innerHTML = '<div class="text-red-400 text-sm">AI failed: ' + (errData.error || 'Unknown') + '</div>'; return; }
          var analysis = await aiRes.json();
          renderAiResult(resultEl, analysis, analysis.recommendation || 'suspicious', false);
        } catch(e) { resultEl.innerHTML = '<div class="text-red-400 text-sm">AI failed: ' + e.message + '</div>'; }
      }
      window.runAiAnalysis = function() { runAiAnalysisBase('ai-result'); };
      window.runAiAnalysisSplit = function() { runAiAnalysisBase('ai-result-split'); };
      function renderAiResult(el, analysis, recommendation, fromCache) {
        var rec = recommendation || 'suspicious';
        if (typeof analysis === 'string') {
          el.innerHTML = '<div class="bg-surface border border-border rounded-lg p-4"><div class="flex items-center gap-2 mb-2"><span class="ai-badge ai-' + rec + '">' + rec.toUpperCase() + '</span><span class="text-xs text-muted-text">' + (fromCache ? '(cached)' : '(fresh)') + '</span></div><p class="text-sm text-muted-text">' + (analysis || '').replace(/</g,'&lt;') + '</p></div>';
          return;
        }
        var html = '<div class="bg-surface border border-border rounded-lg p-4">';
        html += '<div class="flex items-center gap-2 mb-3"><span class="ai-badge ai-' + rec + '">' + rec.toUpperCase() + '</span><span class="text-xs text-muted-text">' + (fromCache ? '(cached)' : '(fresh via NVIDIA NIM)') + '</span></div>';
        if (analysis.analysis) html += '<p class="text-sm text-muted-text mb-3">' + (analysis.analysis || '').replace(/</g,'&lt;') + '</p>';
        if (analysis.summary) html += '<div class="bg-base border border-border rounded-lg p-3 text-sm mb-2"><span class="text-ember-core font-bold">Advisory:</span> <span class="text-white">' + (analysis.summary || '').replace(/</g,'&lt;') + '</span></div>';
        if (analysis.advisory_severity && analysis.advisory_severity !== 'none') html += '<div class="text-xs text-muted-text mb-2">Severity: <span class="text-white font-bold">' + analysis.advisory_severity.toUpperCase() + '</span></div>';
        if (analysis.affected_versions && analysis.affected_versions.length) html += '<div class="text-xs text-muted-text mb-2">Affected: <span class="text-white">' + analysis.affected_versions.join(', ') + '</span></div>';
        if (analysis.safe_versions && analysis.safe_versions.length) html += '<div class="text-xs text-muted-text">Safe: <span class="text-white">' + analysis.safe_versions.join(', ') + '</span></div>';
        html += '</div>';
        el.innerHTML = html;
      }

      // ══════════════════════════════════════════════
      //  NOTES
      // ══════════════════════════════════════════════
      window.toggleNotes = function() { notesVisible = !notesVisible; document.getElementById('notes-overlay').classList.toggle('hidden', !notesVisible); document.getElementById('floating-notes-btn').classList.toggle('hidden', notesVisible); if (notesVisible) { document.getElementById('notes-pkg-name').textContent = selectedPkg || '—'; document.getElementById('notes-textarea').focus(); } };
      function loadNotes(pkgName) { document.getElementById('notes-textarea').value = localStorage.getItem('cpac-notes-' + pkgName) || ''; document.getElementById('notes-pkg-name').textContent = pkgName; }
      document.getElementById('notes-textarea').addEventListener('input', function() { if (selectedPkg) localStorage.setItem('cpac-notes-' + selectedPkg, this.value); });

      // ══════════════════════════════════════════════
      //  SUBMIT FORMS
      // ══════════════════════════════════════════════
      function handleSubmit(suffix) {
        document.getElementById('publish-form' + suffix).addEventListener('submit', async function(e) {
          e.preventDefault();
          var errorEl = document.getElementById('submit-error' + suffix);
          var successEl = document.getElementById('submit-success' + suffix);
          var btn = document.getElementById('submitBtn' + suffix);
          errorEl.classList.add('hidden'); successEl.classList.add('hidden');
          btn.textContent = 'Submitting...'; btn.disabled = true;
          var cs = function(v) { return v ? v.split(',').map(function(s) { return s.trim(); }).filter(Boolean) : []; };
          var body = { submitted_by: currentUser.id, package: document.getElementById('f-package' + suffix).value.trim(), severity: document.getElementById('f-severity' + suffix).value, status: document.getElementById('f-status' + suffix).value, summary: document.getElementById('f-summary' + suffix).value.trim(), description: document.getElementById('f-description' + suffix).value.trim(), affected_versions: JSON.stringify(cs(document.getElementById('f-affected' + suffix).value)), safe_versions: JSON.stringify(cs(document.getElementById('f-safe' + suffix).value)), reference_urls: JSON.stringify(cs(document.getElementById('f-urls' + suffix).value)), cve: document.getElementById('f-cve' + suffix).value.trim() };
          try {
            var res = await fetch(SUPABASE_URL + '/rest/v1/pending_advisories', { method: 'POST', headers: authHeaders(), body: JSON.stringify(body) });
            var data = await res.json();
            if (res.ok) { successEl.textContent = 'Advisory submitted.'; successEl.classList.remove('hidden'); document.getElementById('publish-form' + suffix).reset(); if (selectedPkg) localStorage.removeItem('cpac-notes-' + selectedPkg); loadPackagesNeedingReview(); }
            else { errorEl.textContent = data.message || data.error || 'Failed.'; errorEl.classList.remove('hidden'); }
          } catch(err) { errorEl.textContent = err.message; errorEl.classList.remove('hidden'); }
          btn.textContent = 'Submit Advisory'; btn.disabled = false;
        });
      }
      handleSubmit(''); handleSubmit('-split');

      // ══════════════════════════════════════════════
      //  ACCOUNT MANAGEMENT
      // ══════════════════════════════════════════════
      function loadAccounts() {
        fetch(SUPABASE_URL + '/rest/v1/profiles?select=*&order=created_at.desc', { headers: anonHeaders() })
          .then(function(r) { return r.json(); }).then(function(data) {
            document.getElementById('accounts-loading').classList.add('hidden');
            if (!data || data.length === 0) return;
            document.getElementById('accounts-list').innerHTML = data.map(function(p) {
              return '<div class="account-card" id="acct-' + p.id + '"><div class="flex flex-wrap items-center gap-3 mb-2"><span class="text-white font-bold">' + (p.display_name || 'Unnamed') + '</span><span class="role-badge role-' + p.role + '">' + p.role + '</span><span class="text-xs text-muted-text">' + (p.id ? p.id.substring(0, 8) + '...' : '') + '</span><span class="text-xs text-muted-text ml-auto">Joined ' + new Date(p.created_at).toLocaleDateString() + '</span></div><div class="flex gap-2 mt-2"><button onclick="changeRole(\'' + p.id + '\',\'' + p.role + '\')" class="action-btn bg-elevated hover:bg-cinder-dark text-muted-text border border-border">Change Role</button><button onclick="deleteAccount(\'' + p.id + '\',\'' + (p.display_name || 'Unnamed').replace(/'/g, "\\'") + '\')" class="action-btn bg-red-900 hover:bg-red-800 text-red-200">Delete</button></div><div id="acct-msg-' + p.id + '" class="hidden text-xs mt-2"></div></div>';
            }).join('');
          });
      }
      document.getElementById('createForm').addEventListener('submit', async function(e) {
        e.preventDefault();
        var errorEl = document.getElementById('create-error');
        var successEl = document.getElementById('create-success');
        var btn = document.getElementById('createBtn');
        errorEl.classList.add('hidden'); successEl.classList.add('hidden');
        btn.textContent = 'Creating...'; btn.disabled = true;
        try {
          var res = await fetch(API_PREFIX + '/accounts/create', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ email: document.getElementById('c-email').value.trim(), role: document.getElementById('c-role').value, display_name: document.getElementById('c-name').value.trim() }) });
          var data = await res.json();
          if (!res.ok) { errorEl.textContent = data.error || 'Failed.'; errorEl.classList.remove('hidden'); }
          else { successEl.innerHTML = 'Account created!<br><strong>Email:</strong> ' + data.email + '<br><strong>Temp Password:</strong> <code style="background:#1a1a1a;color:#86efac;padding:2px 6px;border-radius:4px;">' + data.tempPassword + '</code><br><span class="text-xs text-muted-text">Credentials emailed to user.</span>'; successEl.classList.remove('hidden'); document.getElementById('createForm').reset(); loadAccounts(); }
        } catch(err) { errorEl.textContent = err.message; errorEl.classList.remove('hidden'); }
        btn.textContent = 'Create Account'; btn.disabled = false;
      });
      window.changeRole = async function(userId, currentRole) {
        var newRole = currentRole === 'volunteer' ? 'maintainer' : 'volunteer';
        if (!confirm('Change role from ' + currentRole + ' to ' + newRole + '?')) return;
        var msgEl = document.getElementById('acct-msg-' + userId);
        msgEl.className = 'text-xs mt-2 text-yellow-400'; msgEl.textContent = 'Updating...';
        try {
          var res = await fetch(SUPABASE_URL + '/rest/v1/profiles?id=eq.' + userId, { method: 'PATCH', headers: authHeaders(), body: JSON.stringify({ role: newRole }) });
          if (res.ok) { msgEl.className = 'text-xs mt-2 text-green-400'; msgEl.textContent = 'Role changed to ' + newRole; setTimeout(loadAccounts, 1000); }
          else { msgEl.className = 'text-xs mt-2 text-red-400'; msgEl.textContent = 'Error: ' + await res.text(); }
        } catch(e) { msgEl.className = 'text-xs mt-2 text-red-400'; msgEl.textContent = e.message; }
      };
      window.deleteAccount = async function(userId, name) {
        if (!confirm('DELETE "' + name + '"? This cannot be undone.')) return;
        var msgEl = document.getElementById('acct-msg-' + userId);
        msgEl.className = 'text-xs mt-2 text-yellow-400'; msgEl.textContent = 'Deleting...';
        try {
          var res = await fetch(SUPABASE_URL + '/rest/v1/profiles?id=eq.' + userId, { method: 'DELETE', headers: authHeaders() });
          if (res.ok) { msgEl.className = 'text-xs mt-2 text-green-400'; msgEl.textContent = 'Deleted.'; setTimeout(loadAccounts, 1000); }
          else { msgEl.className = 'text-xs mt-2 text-red-400'; msgEl.textContent = 'Error: ' + await res.text(); }
        } catch(e) { msgEl.className = 'text-xs mt-2 text-red-400'; msgEl.textContent = e.message; }
      };

      // ══════════════════════════════════════════════
      //  PENDING / PUBLISHED / INACTIVITY / STATS
      // ══════════════════════════════════════════════
      function loadPending() {
        fetch(SUPABASE_URL + '/rest/v1/pending_advisories?select=*,profiles:submitted_by(display_name)&review_status=eq.pending&order=created_at.asc', { headers: anonHeaders() })
          .then(function(r) { return r.json(); }).then(function(data) {
            document.getElementById('pending-loading').classList.add('hidden');
            document.getElementById('pending-count').textContent = data.length;
            if (data.length === 0) { document.getElementById('pending-empty').classList.remove('hidden'); return; }
            document.getElementById('pending-list').innerHTML = data.map(function(s) {
              var submitter = s.profiles ? s.profiles.display_name : 'Unknown';
              return '<div class="pending-card"><div class="flex flex-wrap items-center gap-2 mb-2"><h3 class="text-lg font-heading text-white">' + s.package + '</h3><span class="severity-badge severity-' + s.severity + '">' + s.severity + '</span><span class="status-badge status-' + s.status + '">' + s.status + '</span><span class="text-xs text-muted-text ml-auto">by ' + submitter + ' — ' + new Date(s.created_at).toLocaleDateString() + '</span></div><p class="text-sm text-muted-text mb-3">' + s.summary + '</p>' + (s.description ? '<p class="text-xs text-muted-text mb-3 whitespace-pre-line">' + s.description + '</p>' : '') + (s.cve ? '<div class="text-xs text-muted-text mb-2">CVE: <span class="text-white">' + s.cve + '</span></div>' : '') + '<div class="flex gap-2 mt-3"><button onclick="approveAdvisory(\'' + s.id + '\')" class="action-btn bg-green-800 hover:bg-green-700 text-green-100">Approve</button><button onclick="rejectAdvisory(\'' + s.id + '\')" class="action-btn bg-red-800 hover:bg-red-700 text-red-100">Reject</button></div><div id="action-msg-' + s.id + '" class="hidden text-xs mt-2"></div></div>';
            }).join('');
          });
      }
      window.approveAdvisory = async function(id) {
        var msgEl = document.getElementById('action-msg-' + id);
        msgEl.className = 'text-xs mt-2 text-green-400'; msgEl.textContent = 'Approving...';
        try { var res = await fetch(SUPABASE_URL + '/rest/v1/rpc/approve_advisory', { method: 'POST', headers: authHeaders(), body: JSON.stringify({ p_pending_id: id, p_reviewed_by: currentUser.id, p_review_notes: '' }) }); if (res.ok) { msgEl.textContent = 'Approved!'; setTimeout(function() { loadPending(); loadPublished(); loadStats(); loadPackagesNeedingReview(); }, 1000); } else { msgEl.className = 'text-xs mt-2 text-red-400'; msgEl.textContent = await res.text(); } } catch(e) { msgEl.className = 'text-xs mt-2 text-red-400'; msgEl.textContent = e.message; }
      };
      window.rejectAdvisory = async function(id) {
        var notes = prompt('Rejection reason (optional):');
        var msgEl = document.getElementById('action-msg-' + id);
        msgEl.className = 'text-xs mt-2 text-yellow-400'; msgEl.textContent = 'Rejecting...';
        try { var res = await fetch(SUPABASE_URL + '/rest/v1/rpc/reject_advisory', { method: 'POST', headers: authHeaders(), body: JSON.stringify({ p_pending_id: id, p_reviewed_by: currentUser.id, p_review_notes: notes || '' }) }); if (res.ok) { msgEl.textContent = 'Rejected.'; setTimeout(function() { loadPending(); loadStats(); }, 1000); } else { msgEl.className = 'text-xs mt-2 text-red-400'; msgEl.textContent = await res.text(); } } catch(e) { msgEl.className = 'text-xs mt-2 text-red-400'; msgEl.textContent = e.message; }
      };
      function loadPublished() {
        fetch(SUPABASE_URL + '/rest/v1/advisories?select=*&order=reported.desc', { headers: anonHeaders() })
          .then(function(r) { return r.json(); }).then(function(data) {
            document.getElementById('published-loading').classList.add('hidden');
            document.getElementById('published-list').innerHTML = data.map(function(a) {
              return '<div class="pending-card"><div class="flex flex-wrap items-center gap-2 mb-1"><span class="text-white font-bold">' + a.package + '</span><span class="severity-badge severity-' + a.severity + '">' + a.severity + '</span><span class="status-badge status-' + a.status + '">' + a.status + '</span></div><p class="text-sm text-muted-text">' + a.summary + '</p><div class="text-xs text-muted-text mt-1">By ' + a.reported_by + ' — ' + a.reported + '</div></div>';
            }).join('');
          });
      }
      function loadInactive() {
        fetch(SUPABASE_URL + '/rest/v1/rpc/check_volunteer_inactivity', { method: 'POST', headers: anonHeaders(), body: JSON.stringify({}) })
          .then(function(r) { return r.json(); }).then(function(data) {
            document.getElementById('inactive-loading').classList.add('hidden');
            if (!data || data.length === 0) { document.getElementById('inactive-empty').classList.remove('hidden'); return; }
            document.getElementById('inactive-list').innerHTML = data.map(function(v) {
              var lastSeen = v.last_submission ? new Date(v.last_submission).toLocaleDateString() : 'Never';
              return '<div class="pending-card"><div class="flex flex-wrap items-center gap-3"><span class="text-white font-bold">' + v.display_name + '</span><span class="text-xs text-muted-text">Last: ' + lastSeen + '</span></div></div>';
            }).join('');
          }).catch(function() { document.getElementById('inactive-loading').classList.add('hidden'); document.getElementById('inactive-empty').classList.remove('hidden'); });
      }
      function loadStats() {
        Promise.all([
          fetch(SUPABASE_URL + '/rest/v1/advisories?select=id', { headers: anonHeaders() }).then(function(r) { return r.json(); }),
          fetch(SUPABASE_URL + '/rest/v1/pending_advisories?select=id&review_status=eq.pending', { headers: anonHeaders() }).then(function(r) { return r.json(); }),
          fetch(SUPABASE_URL + '/rest/v1/profiles?select=id&role=eq.volunteer', { headers: anonHeaders() }).then(function(r) { return r.json(); }),
          fetch(SUPABASE_URL + '/rest/v1/profiles?select=id&role=eq.maintainer', { headers: anonHeaders() }).then(function(r) { return r.json(); })
        ]).then(function(r) {
          document.getElementById('stat-total').textContent = r[0].length;
          document.getElementById('stat-pending').textContent = r[1].length;
          document.getElementById('stat-volunteers').textContent = r[2].length;
          document.getElementById('stat-maintainers').textContent = r[3].length;
        });
      }
      function loadVolunteerReputation() {
        fetch(SUPABASE_URL + '/rest/v1/volunteer_reputation?select=*&order=total_submissions.desc', { headers: anonHeaders() })
          .then(function(r) { return r.json(); }).then(function(data) {
            document.getElementById('admin-rep-loading').classList.add('hidden');
            if (!data || data.length === 0) { document.getElementById('admin-rep-list').innerHTML = '<div class="text-center py-4 text-muted-text">No volunteers.</div>'; return; }
            document.getElementById('admin-rep-list').innerHTML = data.map(function(v) {
              var tc = 'tier-' + (v.trust_tier || 'standard');
              var sc = (v.strikes || 0) >= 2 ? 'text-red-400' : (v.strikes || 0) >= 1 ? 'text-yellow-400' : 'text-muted-text';
              return '<div class="vol-card"><div class="flex flex-wrap items-center gap-4"><div class="min-w-[140px]"><span class="text-white font-bold">' + (v.display_name || 'Unknown') + '</span></div><div><span class="tier-badge ' + tc + '">' + (v.trust_tier || 'standard') + '</span></div><div class="text-sm"><span class="text-muted-text">Rate:</span> <span class="text-white">' + (v.approval_rate || 0) + '%</span></div><div class="text-sm"><span class="text-muted-text">Submitted:</span> <span class="text-white">' + (v.total_submissions || 0) + '</span></div><div class="text-sm"><span class="text-muted-text">Approved:</span> <span class="text-green-400">' + (v.approved || 0) + '</span></div><div class="text-sm"><span class="text-muted-text">Rejected:</span> <span class="text-red-400">' + (v.rejected || 0) + '</span></div><div class="text-sm"><span class="text-muted-text">Strikes:</span> <span class="' + sc + '">' + (v.strikes || 0) + '</span></div></div></div>';
            }).join('');
          });
      }

      document.getElementById('logoutBtn').addEventListener('click', function() {
        supabase.auth.signOut().then(function() { window.location.href = '/cpac-trust-db/web/panel/login/'; });
      });
    })();
  </script>
</MainLayout>
