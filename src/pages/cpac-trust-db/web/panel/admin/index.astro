        } catch(e) { document.getElementById('pkg-list-loading').classList.add('hidden'); document.getElementById('pkg-list-empty').textContent = 'Error: ' + e.message; document.getElementById('pkg-list-empty').classList.remove('hidden'); }
      }
      function renderPackageList(pkgs) {
