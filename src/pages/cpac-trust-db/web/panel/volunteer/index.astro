      // ══════════════════════════════════════════════
      //  AUTOMATED COMPARE
      // ══════════════════════════════════════════════

      async function runAutoCompare(pkgName) {
        var loading = document.getElementById('auto-compare-loading');
        var loadingSplit = document.getElementById('auto-compare-loading-split');
        var error = document.getElementById('auto-compare-error');
        var errorSplit = document.getElementById('auto-compare-error-split');
        var result = document.getElementById('compare-result');
        var resultSplit = document.getElementById('compare-result-split');
        var controls = document.getElementById('manual-controls');
        var controlsSplit = document.getElementById('manual-controls-split');

        // Show loading in current layout
        if (currentLayout === 'tabs') {
          loading.classList.remove('hidden');
          error.classList.add('hidden');
          result.classList.add('hidden');
          controls.classList.add('hidden');
        } else {
          loadingSplit.classList.remove('hidden');
          errorSplit.classList.add('hidden');
          resultSplit.classList.add('hidden');
          controlsSplit.classList.add('hidden');
        }

        try {
          // Fetch snapshots
          var snapRes = await fetch(SUPABASE_URL + '/rest/v1/snapshots?select=*&package=eq.' + encodeURIComponent(pkgName) + '&order=version.desc', { headers: anonHeaders() });
          currentSnapshots = await snapRes.json();

          // Fetch AUR info
          var aurRes = await fetch(WORKER_URL + '/cpac-trust-db/api/aur/info/' + encodeURIComponent(pkgName));
          var aurData = await aurRes.json();

          if (aurData.resultcount === 0 && currentSnapshots.length === 0) {
            var errEl = currentLayout === 'tabs' ? error : errorSplit;
            errEl.textContent = 'Package not found in AUR or trust DB.';
            errEl.classList.remove('hidden');
            if (currentLayout === 'tabs') loading.classList.add('hidden'); else loadingSplit.classList.add('hidden');
            return;
          }

          currentPkgData = {
            name: pkgName,
            aurInfo: aurData.resultcount > 0 ? aurData.results[0] : null,
            snapshots: currentSnapshots,
            versions: [...new Set(currentSnapshots.map(function(s) { return s.version; }))]
          };

          if (currentPkgData.aurInfo && currentPkgData.versions.indexOf(currentPkgData.aurInfo.Version) === -1) {
            currentPkgData.versions.push(currentPkgData.aurInfo.Version);
          }
          currentPkgData.versions.sort();

          // Auto-compare: latest two versions
          if (currentPkgData.versions.length < 2) {
            var errEl2 = currentLayout === 'tabs' ? error : errorSplit;
            errEl2.textContent = 'Only one version available — cannot compare.';
            errEl2.classList.remove('hidden');
            if (currentLayout === 'tabs') loading.classList.add('hidden'); else loadingSplit.classList.add('hidden');
            return;
          }

          var vOld = currentPkgData.versions[currentPkgData.versions.length - 2];
          var vNew = currentPkgData.versions[currentPkgData.versions.length - 1];

          var oldText = await fetchPkgbuild(pkgName, vOld, currentPkgData);
          var newText = await fetchPkgbuild(pkgName, vNew, currentPkgData);

          if (!oldText && !newText) {
            var errEl3 = currentLayout === 'tabs' ? error : errorSplit;
            errEl3.textContent = 'Could not fetch PKGBUILDs for comparison.';
            errEl3.classList.remove('hidden');
            if (currentLayout === 'tabs') loading.classList.add('hidden'); else loadingSplit.classList.add('hidden');
            return;
          }

          var oldHash = oldText ? await sha256(oldText) : null;
          var newHash = newText ? await sha256(newText) : null;
          var diff = computeDiff(oldText || '', newText || '', vOld, vNew);
          var suspicious = detectSuspicious(newText || '');

          // Check advisories
          var advRes2 = await fetch(SUPABASE_URL + '/rest/v1/advisories?select=*&package=eq.' + encodeURIComponent(pkgName), { headers: anonHeaders() });
          var advisories = await advRes2.json();
          var advisory = advisories.length > 0 ? advisories[0] : null;

          var ctx = { pkg: pkgName, vOld: vOld, vNew: vNew, oldHash: oldHash, newHash: newHash, oldText: oldText, newText: newText };
          var html = buildDiffHtml(diff, suspicious, advisory, ctx);

          if (currentLayout === 'tabs') {
            result.innerHTML = html;
            result.classList.remove('hidden');
            controls.classList.remove('hidden');
            loading.classList.add('hidden');
          } else {
            resultSplit.innerHTML = html;
            resultSplit.classList.remove('hidden');
            controlsSplit.classList.remove('hidden');
            loadingSplit.classList.add('hidden');
          }
        } catch(e) {
          var errEl4 = currentLayout === 'tabs' ? error : errorSplit;
          errEl4.textContent = 'Error: ' + e.message;
          errEl4.classList.remove('hidden');
          if (currentLayout === 'tabs') loading.classList.add('hidden'); else loadingSplit.classList.add('hidden');
        }
      }

      // ══════════════════════════════════════════════
      //  SHARED DIFF LOGIC
      // ══════════════════════════════════════════════

      async function fetchPkgbuild(pkg, version, data) {
        var snap = data.snapshots.find(function(s) { return s.version === version && s.pkgbuild_text; });
        if (snap && snap.pkgbuild_text) return snap.pkgbuild_text;
        if (data.aurInfo && data.aurInfo.Version === version) {
          try {
            var res = await fetch(WORKER_URL + '/cpac-trust-db/api/aur/pkgbuild/' + encodeURIComponent(pkg));
            var text = await res.text();
            if (text && text.length > 10 && text.indexOf('#') !== -1) return text;
          } catch(e) {}
        }
        return null;
      }

      function computeDiff(oldText, newText, vOld, vNew) {
        var oldLines = oldText.split('\n');
        var newLines = newText.split('\n');
        var result = { lines: [], stats: { added: 0, removed: 0, unchanged: 0 } };
        var dp = lcsMatrix(oldLines, newLines);
        var i = oldLines.length, j = newLines.length;
        var rawDiff = [];
        while (i > 0 || j > 0) {
          if (i > 0 && j > 0 && oldLines[i-1] === newLines[j-1]) {
            rawDiff.unshift({ type: 'ctx', oldNum: i, newNum: j, text: oldLines[i-1] });
            i--; j--;
          } else if (j > 0 && (i === 0 || dp[i][j-1] >= dp[i-1][j])) {
            rawDiff.unshift({ type: 'add', newNum: j, text: newLines[j-1] });
            result.stats.added++;
            j--;
          } else {
            rawDiff.unshift({ type: 'del', oldNum: i, text: oldLines[i-1] });
            result.stats.removed++;
            i--;
          }
        }
        result.stats.unchanged = rawDiff.filter(function(l) { return l.type === 'ctx'; }).length;
        result.lines = rawDiff;
        return result;
      }

      function lcsMatrix(a, b) {
        var m = a.length, n = b.length;
        var dp = Array.from({ length: m + 1 }, function() { return new Array(n + 1).fill(0); });
        for (var i = 1; i <= m; i++) {
          for (var j = 1; j <= n; j++) {
            dp[i][j] = a[i-1] === b[j-1] ? dp[i-1][j-1] + 1 : Math.max(dp[i-1][j], dp[i][j-1]);
          }
        }
        return dp;
      }

      var SUSPICIOUS_PATTERNS = [
        { re: /curl\s+.*\|\s*(bash|sh)/i, label: 'Remote script via curl pipe', severity: 'high' },
        { re: /wget\s+.*\|\s*(sh|bash)/i, label: 'Remote script via wget pipe', severity: 'high' },
        { re: /fetch\s+.*\|\s*sh/i, label: 'Remote script via fetch pipe', severity: 'high' },
        { re: /\bbase64\s+-d/i, label: 'Base64 decode', severity: 'medium' },
        { re: /\\x[0-9a-f]{2}/i, label: 'Hex escape sequence', severity: 'medium' },
        { re: /\beval\b/i, label: 'eval usage', severity: 'high' },
        { re: /\bexec\b/i, label: 'exec usage', severity: 'medium' },
        { re: /rm\s+-rf\s+[\/~]/i, label: 'Aggressive file removal', severity: 'high' },
        { re: /npm\s+install\s+.*\|\s*(bash|sh|node)/i, label: 'npm install pipe to shell', severity: 'high' },
        { re: /bun\s+install\s+.*\|\s*(bash|sh|node)/i, label: 'bun install pipe to shell', severity: 'high' },
        { re: /npx\s+.*\|\s*(bash|sh)/i, label: 'npx pipe to shell', severity: 'high' },
        { re: /curl\s+.*\|\s*npx/i, label: 'curl pipe to npx', severity: 'high' },
        { re: /wget\s+.*\|\s*npx/i, label: 'wget pipe to npx', severity: 'high' },
        { re: /\beval\s*\(\s*.*base64/i, label: 'eval + base64', severity: 'critical' },
        { re: /\bexport\s+PATH\s*=/i, label: 'PATH modification', severity: 'low' },
        { re: /pacman\s+-S\b/i, label: 'pacman install in build', severity: 'low' },
      ];

      function detectSuspicious(text) {
        var lines = text.split('\n');
        var findings = [];
        lines.forEach(function(line, idx) {
          SUSPICIOUS_PATTERNS.forEach(function(p) {
            if (p.re.test(line)) {
              findings.push({ line: idx + 1, text: line.trim(), label: p.label, severity: p.severity });
            }
          });
        });
        return findings;
      }

      function buildDiffHtml(diff, suspicious, advisory, ctx) {
        var identical = diff.stats.added === 0 && diff.stats.removed === 0;
        var html = '<div class="bg-surface border border-border rounded-xl p-6">';

        html += '<div class="flex flex-wrap items-center gap-3 mb-4">';
        html += '<h3 class="text-xl font-heading text-white">' + ctx.pkg + '</h3>';
        if (identical) html += '<span class="verdict-badge verdict-clean">IDENTICAL</span>';
        else if (suspicious.length > 0) html += '<span class="verdict-badge verdict-advisory">CHANGES DETECTED</span>';
        else html += '<span class="verdict-badge verdict-outdated">MODIFIED</span>';
        html += '</div>';

        html += '<div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-4 text-sm">';
        html += '<div><span class="text-muted-text">Old:</span> <span class="text-white">' + ctx.vOld + '</span></div>';
        html += '<div><span class="text-muted-text">New:</span> <span class="text-white">' + ctx.vNew + '</span></div>';
        html += '<div><span class="text-muted-text">Lines added:</span> <span class="text-green-400">+' + diff.stats.added + '</span></div>';
        html += '<div><span class="text-muted-text">Lines removed:</span> <span class="text-red-400">-' + diff.stats.removed + '</span></div>';
        html += '</div>';

        if (ctx.oldHash || ctx.newHash) {
          html += '<div class="text-xs text-muted-text mb-4 font-mono">';
          if (ctx.oldHash) html += 'Old SHA-256: ' + ctx.oldHash.substring(0, 32) + '...<br>';
          if (ctx.newHash) html += 'New SHA-256: ' + ctx.newHash.substring(0, 32) + '...';
          html += '</div>';
        }

        if (advisory) {
          html += '<div class="bg-red-900/20 border border-red-800 rounded-lg p-3 text-sm mb-4">'
            + '<span class="text-red-400 font-bold">Active Advisory:</span> <span class="text-white">' + advisory.severity.toUpperCase() + '</span> — '
            + advisory.summary + '</div>';
        }

        if (suspicious.length > 0) {
          html += '<div class="bg-yellow-900/20 border border-yellow-800 rounded-lg p-3 text-sm mb-4">';
          html += '<span class="text-yellow-400 font-bold">Suspicious Patterns (' + suspicious.length + '):</span>';
          html += '<ul class="mt-2 space-y-1">';
          suspicious.forEach(function(s) {
            var sevColor = s.severity === 'critical' ? 'text-red-400' : s.severity === 'high' ? 'text-orange-400' : 'text-yellow-400';
            html += '<li class="text-xs"><span class="' + sevColor + '">[' + s.severity.toUpperCase() + ']</span> Line ' + s.line + ': ' + s.label + '</li>';
          });
          html += '</ul></div>';
        }

        if (!identical) {
          html += '<div class="mt-4 border border-border rounded-lg overflow-hidden">';
          html += '<div class="diff-hunk">@@ PKGBUILD Diff: ' + ctx.vOld + ' → ' + ctx.vNew + ' @@</div>';
          var maxShow = 500, shown = 0;
          diff.lines.forEach(function(line) {
            if (shown >= maxShow || line.type === 'ctx') return;
            var cls = line.type === 'add' ? 'diff-add' : 'diff-del';
            var prefix = line.type === 'add' ? '+' : '-';
            var lineNum = line.type === 'add' ? line.newNum : line.oldNum;
            var isSuspicious = suspicious.some(function(s) { return s.line === lineNum; });
            html += '<div class="diff-line ' + cls + (isSuspicious ? ' suspicious-highlight' : '') + '">'
              + prefix + ' ' + escapeHtml(line.text) + '</div>';
            shown++;
          });
          if (diff.lines.length > maxShow) html += '<div class="diff-line diff-ctx">... ' + (diff.lines.length - maxShow) + ' more lines</div>';
          html += '</div>';
        } else {
          html += '<div class="text-center py-6 text-muted-text text-sm">PKGBUILDs are identical — no changes detected.</div>';
        }

        html += '</div>';
        return html;
      }

      function escapeHtml(t) {
        return t.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
      }

      // ── Manual re-compare ──
      window.runManualCompare = function() {
        if (!selectedPkg) return;
        runAutoCompare(selectedPkg);
      };
      window.runManualCompareSplit = window.runManualCompare;

      // ══════════════════════════════════════════════
      //  AI Analysis — on-demand, 3-hour cache
      // ══════════════════════════════════════════════

      async function runAiAnalysisBase(resultElId) {
        if (!currentPkgData || !selectedPkg) return;
        var versions = currentPkgData.versions;
        var vOld = versions[versions.length - 2];
        var vNew = versions[versions.length - 1];
        var resultEl = document.getElementById(resultElId);

        var oldText = await fetchPkgbuild(selectedPkg, vOld, currentPkgData);
        var newText = await fetchPkgbuild(selectedPkg, vNew, currentPkgData);

        resultEl.classList.remove('hidden');
        resultEl.innerHTML = '<div class="text-muted-text text-sm">Checking AI cache...</div>';

        try {
          var diffHash = await sha256((oldText || '') + '---' + (newText || ''));

          var cacheRes = await fetch(SUPABASE_URL + '/rest/v1/ai_analysis?select=*&package=eq.' + encodeURIComponent(selectedPkg)
            + '&version_old=eq.' + encodeURIComponent(vOld)
            + '&version_new=eq.' + encodeURIComponent(vNew)
            + '&diff_hash=eq.' + diffHash
            + '&expires_at=gt.' + new Date().toISOString(), { headers: anonHeaders() });
          var cached = await cacheRes.json();

          if (cached && cached.length > 0) {
            var parsed = cached[0].analysis;
            try { parsed = JSON.parse(parsed); } catch(e) {}
            renderAiResult(resultEl, parsed, cached[0].recommendation, true);
            return;
          }

          resultEl.innerHTML = '<div class="text-muted-text text-sm">Running AI analysis via NVIDIA NIM...</div>';

          // Detect suspicious patterns for context
          var suspicious = detectSuspicious(newText || '');

          var aiRes = await fetch(WORKER_URL + '/cpac-trust-db/api/ai/analyze-diff', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              package: selectedPkg,
              version_old: vOld,
              version_new: vNew,
              old_pkgbuild: oldText || '',
              new_pkgbuild: newText || '',
              suspicious_patterns: suspicious
            })
          });

          if (!aiRes.ok) {
            var errData = await aiRes.json().catch(function() { return { error: 'AI request failed' }; });
            resultEl.innerHTML = '<div class="text-red-400 text-sm">AI analysis failed: ' + (errData.error || 'Unknown error') + '</div>';
            return;
          }

          var analysis = await aiRes.json();
          renderAiResult(resultEl, analysis, analysis.recommendation || 'suspicious', false);
        } catch(e) {
          resultEl.innerHTML = '<div class="text-red-400 text-sm">AI analysis failed: ' + e.message + '</div>';
        }
      }

      window.runAiAnalysis = function() { runAiAnalysisBase('ai-result'); };
      window.runAiAnalysisSplit = function() { runAiAnalysisBase('ai-result-split'); };

      function renderAiResult(el, analysis, recommendation, fromCache) {
        var badgeClass = 'ai-' + recommendation;
        var rec = recommendation || 'suspicious';
        if (typeof analysis === 'string') {
          el.innerHTML = '<div class="bg-surface border border-border rounded-lg p-4"><div class="flex items-center gap-2 mb-2"><span class="ai-badge ' + badgeClass + '">' + rec.toUpperCase() + '</span><span class="text-xs text-muted-text">' + (fromCache ? '(cached, < 3 hours)' : '(fresh analysis)') + '</span></div><p class="text-sm text-muted-text">' + escapeHtml(analysis) + '</p></div>';
          return;
        }
        var html = '<div class="bg-surface border border-border rounded-lg p-4">';
        html += '<div class="flex items-center gap-2 mb-3"><span class="ai-badge ' + badgeClass + '">' + rec.toUpperCase() + '</span><span class="text-xs text-muted-text">' + (fromCache ? '(cached, < 3 hours)' : '(fresh analysis via NVIDIA NIM)') + '</span></div>';
        if (analysis.analysis) html += '<p class="text-sm text-muted-text mb-3">' + escapeHtml(analysis.analysis) + '</p>';
        if (analysis.summary) html += '<div class="bg-base border border-border rounded-lg p-3 text-sm mb-2"><span class="text-ember-core font-bold">Advisory Summary:</span> <span class="text-white">' + escapeHtml(analysis.summary) + '</span></div>';
        if (analysis.advisory_severity && analysis.advisory_severity !== 'none') html += '<div class="text-xs text-muted-text mb-2">Recommended severity: <span class="text-white font-bold">' + analysis.advisory_severity.toUpperCase() + '</span></div>';
        if (analysis.affected_versions && analysis.affected_versions.length) html += '<div class="text-xs text-muted-text mb-2">Affected: <span class="text-white">' + analysis.affected_versions.join(', ') + '</span></div>';
        if (analysis.safe_versions && analysis.safe_versions.length) html += '<div class="text-xs text-muted-text mb-2">Safe: <span class="text-white">' + analysis.safe_versions.join(', ') + '</span></div>';
        if (analysis.references && analysis.references.length) html += '<div class="text-xs text-muted-text">References: ' + analysis.references.map(function(r) { return '<a href="' + r + '" target="_blank" class="text-ember-core hover:underline">' + r + '</a>'; }).join(', ') + '</div>';
        html += '</div>';
        el.innerHTML = html;
      }

      // ══════════════════════════════════════════════
      //  NOTES — localStorage persistence
      // ══════════════════════════════════════════════

      window.toggleNotes = function() {
        notesVisible = !notesVisible;
        document.getElementById('notes-overlay').classList.toggle('hidden', !notesVisible);
        document.getElementById('floating-notes-btn').classList.toggle('hidden', notesVisible);
        if (notesVisible) {
          document.getElementById('notes-pkg-name').textContent = selectedPkg || '—';
          document.getElementById('notes-textarea').focus();
        }
      };

      function loadNotes(pkgName) {
        var key = 'cpac-notes-' + pkgName;
        var notes = localStorage.getItem(key) || '';
        document.getElementById('notes-textarea').value = notes;
        document.getElementById('notes-pkg-name').textContent = pkgName;
      }

      // Auto-save notes on input
      document.getElementById('notes-textarea').addEventListener('input', function() {
        if (!selectedPkg) return;
        var key = 'cpac-notes-' + selectedPkg;
        localStorage.setItem(key, this.value);
      });

      function clearNotes(pkgName) {
        localStorage.removeItem('cpac-notes-' + pkgName);
      }

      // ══════════════════════════════════════════════
      //  SUBMIT FORM (tabbed + split)
      // ══════════════════════════════════════════════

      function handleSubmit(suffix) {
        var errorEl = document.getElementById('submit-error' + suffix);
        var successEl = document.getElementById('submit-success' + suffix);
        var btn = document.getElementById('submitBtn' + suffix);
        var form = document.getElementById('publish-form' + suffix);

        form.addEventListener('submit', async function(e) {
          e.preventDefault();
          errorEl.classList.add('hidden');
          successEl.classList.add('hidden');
          btn.textContent = 'Submitting...';
          btn.disabled = true;

          var commaSplit = function(v) { return v ? v.split(',').map(function(s) { return s.trim(); }).filter(Boolean) : []; };
          var body = {
            submitted_by: currentUser.id,
            package: document.getElementById('f-package' + suffix).value.trim(),
            severity: document.getElementById('f-severity' + suffix).value,
            status: document.getElementById('f-status' + suffix).value,
            summary: document.getElementById('f-summary' + suffix).value.trim(),
            description: document.getElementById('f-description' + suffix).value.trim(),
            affected_versions: JSON.stringify(commaSplit(document.getElementById('f-affected' + suffix).value)),
            safe_versions: JSON.stringify(commaSplit(document.getElementById('f-safe' + suffix).value)),
            reference_urls: JSON.stringify(commaSplit(document.getElementById('f-urls' + suffix).value)),
            cve: document.getElementById('f-cve' + suffix).value.trim()
          };

          try {
            var res = await fetch(SUPABASE_URL + '/rest/v1/pending_advisories', { method: 'POST', headers: authHeaders(), body: JSON.stringify(body) });
            var data = await res.json();
            if (res.ok) {
              successEl.textContent = 'Advisory submitted for review.';
              successEl.classList.remove('hidden');
              form.reset();
              // Clear notes for this package
              if (selectedPkg) clearNotes(selectedPkg);
              loadDailyCount();
              loadSubmissions();
              loadPackagesNeedingReview();
            } else {
              errorEl.textContent = data.message || data.error || 'Submission failed.';
              errorEl.classList.remove('hidden');
            }
          } catch(err) {
            errorEl.textContent = 'Network error: ' + err.message;
            errorEl.classList.remove('hidden');
          }
          btn.textContent = 'Submit for Review';
          btn.disabled = false;
        });
      }

      handleSubmit('');
      handleSubmit('-split');

      // ── My Submissions ──
      function loadSubmissions() {
        fetch(SUPABASE_URL + '/rest/v1/pending_advisories?select=*&submitted_by=eq.' + currentUser.id + '&order=created_at.desc', {
          headers: anonHeaders()
        }).then(function(r) { return r.json(); }).then(function(data) {
          document.getElementById('subs-loading').classList.add('hidden');
          if (!data || data.length === 0) { document.getElementById('subs-empty').classList.remove('hidden'); return; }
          var html = data.map(function(s) {
            return '<div class="sub-card">'
              + '<div class="flex flex-wrap items-center gap-2 mb-2">'
              + '<span class="text-white font-bold">' + s.package + '</span>'
              + '<span class="review-badge review-' + s.review_status + '">' + s.review_status + '</span>'
              + '<span class="pkg-card-status status-' + (s.severity === 'critical' ? 'none' : 'stale') + '" style="font-size:0.65rem">' + s.severity + '</span>'
              + '</div>'
              + '<p class="text-sm text-muted-text">' + s.summary + '</p>'
              + (s.review_notes ? '<p class="text-xs text-ember-light mt-1">Reviewer: ' + s.review_notes + '</p>' : '')
              + '<div class="text-xs text-muted-text mt-1">' + new Date(s.created_at).toLocaleDateString() + '</div>'
              + '</div>';
          }).join('');
          document.getElementById('subs-list').innerHTML = html;
        });
      }

      // ── Logout ──
      document.getElementById('logoutBtn').addEventListener('click', function() {
        supabase.auth.signOut().then(function() { window.location.href = '/cpac-trust-db/web/panel/login/'; });
      });
    })();
  </script>
</MainLayout>
