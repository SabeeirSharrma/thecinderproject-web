---
import MainLayout from '../../../../../layouts/MainLayout.astro';
---

<MainLayout title="Volunteer Panel" description="CPAC Trust DB — Volunteer Advisory Submission">
  <div class="container mx-auto px-4 py-16 max-w-7xl">

    <!-- Auth Gate -->
    <div id="auth-gate" class="text-center py-20">
      <p class="text-muted-text">Checking access...</p>
    </div>

    <!-- Dashboard (hidden until auth) -->
    <div id="dashboard" class="hidden">

      <!-- Header -->
      <header class="mb-8 flex flex-wrap items-center justify-between gap-4">
        <div>
          <h1 class="text-3xl font-heading text-white uppercase tracking-widest">Volunteer Panel</h1>
          <p class="text-muted-text text-sm mt-1">Submit advisories for review</p>
        </div>
        <div class="flex items-center gap-4">
          <div class="text-right">
            <div class="text-xs text-muted-text">Submissions today</div>
            <div class="text-lg font-heading text-ember-core" id="daily-count">0/5</div>
          </div>
          <button id="logoutBtn" class="text-xs text-muted-text hover:text-ember-core border border-border rounded-lg px-3 py-2 cursor-pointer transition-colors bg-surface">
            Sign Out
          </button>
        </div>
      </header>

      <!-- Reputation Card -->
      <div id="reputation-card" class="hidden bg-surface border border-border rounded-xl p-4 mb-6">
        <div class="flex flex-wrap items-center gap-6 text-sm">
          <div>
            <span class="text-muted-text text-xs uppercase tracking-widest">Trust Tier</span>
            <div id="rep-tier" class="text-white font-heading text-lg">—</div>
          </div>
          <div>
            <span class="text-muted-text text-xs uppercase tracking-widest">Approval Rate</span>
            <div id="rep-rate" class="text-white font-heading text-lg">—</div>
          </div>
          <div>
            <span class="text-muted-text text-xs uppercase tracking-widest">Submissions</span>
            <div id="rep-total" class="text-white font-heading text-lg">—</div>
          </div>
          <div>
            <span class="text-muted-text text-xs uppercase tracking-widest">Approved</span>
            <div id="rep-approved" class="text-green-400 font-heading text-lg">—</div>
          </div>
          <div>
            <span class="text-muted-text text-xs uppercase tracking-widest">Rejected</span>
            <div id="rep-rejected" class="text-red-400 font-heading text-lg">—</div>
          </div>
          <div>
            <span class="text-muted-text text-xs uppercase tracking-widest">Strikes</span>
            <div id="rep-strikes" class="text-white font-heading text-lg">0</div>
          </div>
        </div>
      </div>

      <!-- Tabs -->
      <div class="flex gap-1 mb-8 border-b border-border">
        <button id="tab-review" class="tab-btn active" onclick="showTab('review')">Review</button>
        <button id="tab-mysubmissions" class="tab-btn" onclick="showTab('mysubmissions')">My Submissions</button>
      </div>

      <!-- ════════════════════════════════════════════════════════════ -->
      <!-- REVIEW TAB                                                  -->
      <!-- ════════════════════════════════════════════════════════════ -->
      <div id="panel-review" class="tab-panel">

        <!-- Layout Toggle -->
        <div class="flex items-center justify-between mb-4">
          <div class="flex items-center gap-3">
            <span class="text-xs text-muted-text uppercase tracking-widest">Layout:</span>
            <button id="layout-tabs-btn" class="layout-btn active" onclick="setLayout('tabs')">Tabs</button>
            <button id="layout-split-btn" class="layout-btn" onclick="setLayout('split')">Split</button>
          </div>
          <button id="notes-toggle-btn" class="notes-btn" onclick="toggleNotes()">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><path d="M14 2v6h6"/><path d="M16 13H8"/><path d="M16 17H8"/><path d="M10 9H8"/></svg>
            Notes
          </button>
        </div>

        <!-- Package List (always shown at top) -->
        <div class="bg-surface border border-border rounded-xl p-4 mb-6">
          <div class="flex flex-wrap items-center justify-between gap-3 mb-3">
            <h2 class="text-lg font-heading text-white uppercase tracking-widest">Packages Needing Review</h2>
            <div class="relative">
              <input type="text" id="pkg-filter" placeholder="Filter packages..."
                class="bg-base border border-border rounded-lg px-3 py-2 text-white text-sm font-body outline-none focus:border-ember-core transition-colors w-48" />
            </div>
          </div>
          <div id="pkg-list-loading" class="text-center py-4 text-muted-text text-sm">Loading packages...</div>
          <div id="pkg-list-empty" class="hidden text-center py-4 text-muted-text text-sm">No packages need advisories.</div>
          <div id="pkg-list" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-2 max-h-64 overflow-y-auto"></div>
        </div>

        <!-- Selected Package Review Area -->
        <div id="review-area" class="hidden">

          <!-- TABBED LAYOUT -->
          <div id="layout-tabs" class="">
            <!-- Tabs for publish/review -->
            <div class="flex gap-1 mb-6 border-b border-border">
              <button id="inner-tab-publish" class="tab-btn active" onclick="showInnerTab('publish')">Publish Advisory</button>
              <button id="inner-tab-review" class="tab-btn" onclick="showInnerTab('review')">Comparer & AI</button>
            </div>

            <div id="inner-panel-publish" class="inner-panel">
              <form id="publish-form" class="bg-surface border border-border rounded-xl p-6 space-y-4">
                <h3 class="text-lg font-heading text-white mb-2 uppercase tracking-widest">Submit Advisory</h3>
                <p class="text-sm text-muted-text mb-4">Review the comparison results first, then fill in the advisory details.</p>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                  <div>
                    <label class="block text-xs font-bold tracking-widest uppercase text-muted-text mb-1">Package Name *</label>
                    <input type="text" id="f-package" required
                      class="w-full bg-base border border-border rounded-lg px-4 py-3 text-white text-sm font-body outline-none focus:border-ember-core transition-colors" />
                  </div>
                  <div>
                    <label class="block text-xs font-bold tracking-widest uppercase text-muted-text mb-1">CVE ID</label>
                    <input type="text" id="f-cve" placeholder="CVE-YYYY-NNNNN"
                      class="w-full bg-base border border-border rounded-lg px-4 py-3 text-white text-sm font-body outline-none focus:border-ember-core transition-colors" />
                  </div>
                  <div>
                    <label class="block text-xs font-bold tracking-widest uppercase text-muted-text mb-1">Severity *</label>
                    <select id="f-severity" required
                      class="w-full bg-base border border-border rounded-lg px-4 py-3 text-white text-sm font-body outline-none focus:border-ember-core transition-colors">
                      <option value="critical">Critical</option>
                      <option value="high">High</option>
                      <option value="medium" selected>Medium</option>
                      <option value="low">Low</option>
                    </select>
                  </div>
                  <div>
                    <label class="block text-xs font-bold tracking-widest uppercase text-muted-text mb-1">Status *</label>
                    <select id="f-status" required
                      class="w-full bg-base border border-border rounded-lg px-4 py-3 text-white text-sm font-body outline-none focus:border-ember-core transition-colors">
                      <option value="suspected" selected>Suspected</option>
                      <option value="confirmed">Confirmed</option>
                    </select>
                  </div>
                </div>

                <div>
                  <label class="block text-xs font-bold tracking-widest uppercase text-muted-text mb-1">Summary *</label>
                  <input type="text" id="f-summary" required placeholder="Brief one-line description"
                    class="w-full bg-base border border-border rounded-lg px-4 py-3 text-white text-sm font-body outline-none focus:border-ember-core transition-colors" />
                </div>

                <div>
                  <label class="block text-xs font-bold tracking-widest uppercase text-muted-text mb-1">Description</label>
                  <textarea id="f-description" rows="3" placeholder="Detailed explanation of the issue"
                    class="w-full bg-base border border-border rounded-lg px-4 py-3 text-white text-sm font-body outline-none focus:border-ember-core transition-colors resize-y"></textarea>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                  <div>
                    <label class="block text-xs font-bold tracking-widest uppercase text-muted-text mb-1">Affected Versions</label>
                    <input type="text" id="f-affected" placeholder="1.0, 1.1, 1.2 (comma-separated)"
                      class="w-full bg-base border border-border rounded-lg px-4 py-3 text-white text-sm font-body outline-none focus:border-ember-core transition-colors" />
                  </div>
                  <div>
                    <label class="block text-xs font-bold tracking-widest uppercase text-muted-text mb-1">Safe Versions</label>
                    <input type="text" id="f-safe" placeholder="1.3, 1.4 (comma-separated)"
                      class="w-full bg-base border border-border rounded-lg px-4 py-3 text-white text-sm font-body outline-none focus:border-ember-core transition-colors" />
                  </div>
                  <div>
                    <label class="block text-xs font-bold tracking-widest uppercase text-muted-text mb-1">Reference URLs</label>
                    <input type="text" id="f-urls" placeholder="https://... (comma-separated)"
                      class="w-full bg-base border border-border rounded-lg px-4 py-3 text-white text-sm font-body outline-none focus:border-ember-core transition-colors" />
                  </div>
                </div>

                <div id="submit-error" class="hidden text-sm text-red-400 bg-red-900/20 border border-red-800 rounded-lg px-4 py-2"></div>
                <div id="submit-success" class="hidden text-sm text-green-400 bg-green-900/20 border border-green-800 rounded-lg px-4 py-2"></div>

                <button type="submit" id="submitBtn"
                  class="bg-ember-core hover:bg-ember-deep text-white font-heading font-bold uppercase tracking-widest text-sm px-6 py-3 rounded-lg transition-colors cursor-pointer">
                  Submit for Review
                </button>
              </form>
            </div>

            <div id="inner-panel-review" class="inner-panel hidden">
              <!-- Automated Compare Result -->
              <div id="auto-compare-loading" class="text-center py-8 text-muted-text">Running automated comparison...</div>
              <div id="auto-compare-error" class="hidden bg-red-900/20 border border-red-800 rounded-xl p-4 text-red-400 text-sm mb-6"></div>
              <div id="compare-result" class="hidden"></div>

              <!-- Manual Controls -->
              <div id="manual-controls" class="hidden mt-4 flex flex-wrap gap-3">
                <button id="recompare-btn" onclick="runManualCompare()"
                  class="bg-surface hover:bg-elevated text-muted-text font-heading font-bold uppercase tracking-widest text-xs px-4 py-2 rounded-lg transition-colors cursor-pointer border border-border">
                  Recompare
                </button>
                <button id="ai-analyze-btn" onclick="runAiAnalysis()"
                  class="bg-cinder-mid hover:bg-cinder-dark text-white font-heading font-bold uppercase tracking-widest text-xs px-4 py-2 rounded-lg transition-colors cursor-pointer">
                  Analyze with AI
                </button>
              </div>
              <div id="ai-result" class="hidden mt-4"></div>
            </div>
          </div>

          <!-- SPLIT LAYOUT (hidden by default) -->
          <div id="layout-split" class="hidden">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
              <!-- Left: Publish -->
              <div>
                <form id="publish-form-split" class="bg-surface border border-border rounded-xl p-6 space-y-4">
                  <h3 class="text-lg font-heading text-white mb-2 uppercase tracking-widest">Submit Advisory</h3>
                  <p class="text-sm text-muted-text mb-4">Review the comparison results first, then fill in the advisory details.</p>

                  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                      <label class="block text-xs font-bold tracking-widest uppercase text-muted-text mb-1">Package Name *</label>
                      <input type="text" id="f-package-split" required
                        class="w-full bg-base border border-border rounded-lg px-4 py-3 text-white text-sm font-body outline-none focus:border-ember-core transition-colors" />
                    </div>
                    <div>
                      <label class="block text-xs font-bold tracking-widest uppercase text-muted-text mb-1">CVE ID</label>
                      <input type="text" id="f-cve-split" placeholder="CVE-YYYY-NNNNN"
                        class="w-full bg-base border border-border rounded-lg px-4 py-3 text-white text-sm font-body outline-none focus:border-ember-core transition-colors" />
                    </div>
                    <div>
                      <label class="block text-xs font-bold tracking-widest uppercase text-muted-text mb-1">Severity *</label>
                      <select id="f-severity-split" required
                        class="w-full bg-base border border-border rounded-lg px-4 py-3 text-white text-sm font-body outline-none focus:border-ember-core transition-colors">
                        <option value="critical">Critical</option>
                        <option value="high">High</option>
                        <option value="medium" selected>Medium</option>
                        <option value="low">Low</option>
                      </select>
                    </div>
                    <div>
                      <label class="block text-xs font-bold tracking-widest uppercase text-muted-text mb-1">Status *</label>
                      <select id="f-status-split" required
                        class="w-full bg-base border border-border rounded-lg px-4 py-3 text-white text-sm font-body outline-none focus:border-ember-core transition-colors">
                        <option value="suspected" selected>Suspected</option>
                        <option value="confirmed">Confirmed</option>
                      </select>
                    </div>
                  </div>

                  <div>
                    <label class="block text-xs font-bold tracking-widest uppercase text-muted-text mb-1">Summary *</label>
                    <input type="text" id="f-summary-split" required placeholder="Brief one-line description"
                      class="w-full bg-base border border-border rounded-lg px-4 py-3 text-white text-sm font-body outline-none focus:border-ember-core transition-colors" />
                  </div>

                  <div>
                    <label class="block text-xs font-bold tracking-widest uppercase text-muted-text mb-1">Description</label>
                    <textarea id="f-description-split" rows="3" placeholder="Detailed explanation of the issue"
                      class="w-full bg-base border border-border rounded-lg px-4 py-3 text-white text-sm font-body outline-none focus:border-ember-core transition-colors resize-y"></textarea>
                  </div>

                  <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                    <div>
                      <label class="block text-xs font-bold tracking-widest uppercase text-muted-text mb-1">Affected Versions</label>
                      <input type="text" id="f-affected-split" placeholder="1.0, 1.1, 1.2 (comma-separated)"
                        class="w-full bg-base border border-border rounded-lg px-4 py-3 text-white text-sm font-body outline-none focus:border-ember-core transition-colors" />
                    </div>
                    <div>
                      <label class="block text-xs font-bold tracking-widest uppercase text-muted-text mb-1">Safe Versions</label>
                      <input type="text" id="f-safe-split" placeholder="1.3, 1.4 (comma-separated)"
                        class="w-full bg-base border border-border rounded-lg px-4 py-3 text-white text-sm font-body outline-none focus:border-ember-core transition-colors" />
                    </div>
                    <div>
                      <label class="block text-xs font-bold tracking-widest uppercase text-muted-text mb-1">Reference URLs</label>
                      <input type="text" id="f-urls-split" placeholder="https://... (comma-separated)"
                        class="w-full bg-base border border-border rounded-lg px-4 py-3 text-white text-sm font-body outline-none focus:border-ember-core transition-colors" />
                    </div>
                  </div>

                  <div id="submit-error-split" class="hidden text-sm text-red-400 bg-red-900/20 border border-red-800 rounded-lg px-4 py-2"></div>
                  <div id="submit-success-split" class="hidden text-sm text-green-400 bg-green-900/20 border border-green-800 rounded-lg px-4 py-2"></div>

                  <button type="submit" id="submitBtn-split"
                    class="bg-ember-core hover:bg-ember-deep text-white font-heading font-bold uppercase tracking-widest text-sm px-6 py-3 rounded-lg transition-colors cursor-pointer">
                    Submit for Review
                  </button>
                </form>
              </div>

              <!-- Right: Compare + AI -->
              <div>
                <div id="auto-compare-loading-split" class="hidden text-center py-8 text-muted-text">Running automated comparison...</div>
                <div id="auto-compare-error-split" class="hidden bg-red-900/20 border border-red-800 rounded-xl p-4 text-red-400 text-sm mb-6"></div>
                <div id="compare-result-split" class="hidden"></div>

                <div id="manual-controls-split" class="hidden mt-4 flex flex-wrap gap-3">
                  <button id="recompare-btn-split" onclick="runManualCompareSplit()"
                    class="bg-surface hover:bg-elevated text-muted-text font-heading font-bold uppercase tracking-widest text-xs px-4 py-2 rounded-lg transition-colors cursor-pointer border border-border">
                    Recompare
                  </button>
                  <button id="ai-analyze-btn-split" onclick="runAiAnalysisSplit()"
                    class="bg-cinder-mid hover:bg-cinder-dark text-white font-heading font-bold uppercase tracking-widest text-xs px-4 py-2 rounded-lg transition-colors cursor-pointer">
                    Analyze with AI
                  </button>
                </div>
                <div id="ai-result-split" class="hidden mt-4"></div>
              </div>
            </div>
          </div>

        </div>
      </div>

      <!-- ════════════════════════════════════════════════════════════ -->
      <!-- MY SUBMISSIONS TAB                                          -->
      <!-- ════════════════════════════════════════════════════════════ -->
      <div id="panel-mysubmissions" class="tab-panel hidden">
        <div id="subs-loading" class="text-center py-8 text-muted-text">Loading submissions...</div>
        <div id="subs-empty" class="hidden text-center py-8">
          <p class="text-muted-text">No submissions yet.</p>
        </div>
        <div id="subs-list" class="space-y-3"></div>
      </div>

    </div>
  </div>

  <!-- ════════════════════════════════════════════════════════════ -->
  <!-- NOTES OVERLAY                                                -->
  <!-- ════════════════════════════════════════════════════════════ -->
  <div id="notes-overlay" class="hidden fixed bottom-4 right-4 z-50 w-80 bg-base border border-border rounded-xl shadow-2xl overflow-hidden">
    <div class="flex items-center justify-between px-4 py-3 bg-surface border-b border-border">
      <span class="text-sm font-heading text-white uppercase tracking-widest">Notes — <span id="notes-pkg-name">—</span></span>
      <button onclick="toggleNotes()" class="text-muted-text hover:text-white cursor-pointer text-lg">&times;</button>
    </div>
    <textarea id="notes-textarea" placeholder="Write your notes here..."
      class="w-full h-48 p-4 bg-transparent text-white text-sm font-body outline-none resize-none placeholder-muted-text"></textarea>
    <div class="px-4 py-2 bg-surface border-t border-border text-xs text-muted-text">
      Auto-saved to browser storage
    </div>
  </div>

  <!-- Floating Notes Button -->
  <button id="floating-notes-btn" class="hidden fixed bottom-4 right-4 z-40 bg-cinder-mid hover:bg-cinder-dark text-white font-heading font-bold uppercase tracking-widest text-xs px-4 py-3 rounded-lg transition-colors cursor-pointer shadow-lg"
    onclick="toggleNotes()">
    <svg class="inline-block mr-1" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><path d="M14 2v6h6"/><path d="M16 13H8"/><path d="M16 17H8"/><path d="M10 9H8"/></svg>
    Notes
  </button>

  <style>
    .tab-btn {
      padding: 0.75rem 1.5rem; font-family: var(--font-heading); font-weight: 600;
      text-transform: uppercase; letter-spacing: 0.1em; font-size: 0.875rem;
      color: var(--color-muted-text); border-bottom: 2px solid transparent;
      transition: all 0.2s; cursor: pointer; background: none;
      border-top: none; border-left: none; border-right: none;
    }
    .tab-btn:hover { color: var(--color-ember-light); }
    .tab-btn.active { color: var(--color-ember-core); border-bottom-color: var(--color-ember-core); }
    .layout-btn {
      padding: 0.375rem 0.75rem; font-family: var(--font-heading); font-weight: 600;
      text-transform: uppercase; letter-spacing: 0.05em; font-size: 0.7rem;
      color: var(--color-muted-text); border: 1px solid var(--color-border);
      border-radius: 0.375rem; cursor: pointer; background: none; transition: all 0.15s;
    }
    .layout-btn:hover { color: var(--color-white); border-color: var(--color-cinder-mid); }
    .layout-btn.active { color: var(--color-ember-core); border-color: var(--color-ember-core); background: rgba(239,68,68,0.08); }
    .notes-btn {
      padding: 0.375rem 0.75rem; font-family: var(--font-heading); font-weight: 600;
      text-transform: uppercase; letter-spacing: 0.05em; font-size: 0.7rem;
      color: var(--color-muted-text); border: 1px solid var(--color-border);
      border-radius: 0.375rem; cursor: pointer; background: none; transition: all 0.15s;
      display: inline-flex; align-items: center; gap: 0.375rem;
    }
    .notes-btn:hover { color: var(--color-white); border-color: var(--color-cinder-mid); }
    .pkg-card {
      background: var(--color-surface); border: 1px solid var(--color-border);
      border-radius: 0.5rem; padding: 0.75rem 1rem; cursor: pointer;
      transition: all 0.15s; font-size: 0.875rem;
    }
    .pkg-card:hover { border-color: var(--color-ember-core); background: var(--color-elevated); }
    .pkg-card.selected { border-color: var(--color-ember-core); background: rgba(239,68,68,0.08); }
    .pkg-card-name { font-family: var(--font-heading); font-weight: 600; color: var(--color-white); }
    .pkg-card-version { font-size: 0.75rem; color: var(--color-muted-text); }
    .pkg-card-status {
      display: inline-block; padding: 0.1rem 0.4rem; border-radius: 9999px;
      font-size: 0.65rem; font-weight: 700; text-transform: uppercase;
    }
    .status-none { background: #1e3a5f; color: #93c5fd; }
    .status-stale { background: #713f12; color: #fde68a; }
    .verdict-badge {
      display: inline-block; padding: 0.25rem 0.75rem; border-radius: 9999px;
      font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em;
    }
    .verdict-clean { background: #14532d; color: #86efac; }
    .verdict-advisory { background: #7f1d1d; color: #fca5a5; }
    .verdict-divergent { background: #7f1d1d; color: #fca5a5; }
    .verdict-outdated { background: #713f12; color: #fde68a; }
    .verdict-unknown { background: #1e3a5f; color: #93c5fd; }
    .diff-line { font-family: 'SF Mono', 'Fira Code', monospace; font-size: 0.8rem; padding: 0.1rem 0.5rem; white-space: pre-wrap; word-break: break-all; }
    .diff-add { background: #14532d40; color: #86efac; }
    .diff-del { background: #7f1d1d40; color: #fca5a5; }
    .diff-ctx { color: var(--color-muted-text); }
    .diff-hunk { color: var(--color-ember-core); font-weight: 600; font-size: 0.75rem; padding: 0.3rem 0.5rem; background: var(--color-surface); }
    .suspicious-highlight { background: #f59e0b30; border-left: 3px solid #f59e0b; }
    .ai-badge {
      display: inline-block; padding: 0.15rem 0.5rem; border-radius: 4px;
      font-size: 0.7rem; font-weight: 700; text-transform: uppercase;
    }
    .ai-safe { background: #14532d; color: #86efac; }
    .ai-suspicious { background: #713f12; color: #fde68a; }
    .ai-malicious { background: #7f1d1d; color: #fca5a5; }
    .tier-trusted { color: #86efac; }
    .tier-standard { color: #93c5fd; }
    .tier-probation { color: #fde68a; }
    .tier-suspended { color: #fca5a5; }
    .review-badge {
      display: inline-block; padding: 0.125rem 0.5rem; border-radius: 9999px;
