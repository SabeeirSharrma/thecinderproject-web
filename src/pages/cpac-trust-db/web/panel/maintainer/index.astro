      }

      // ══════════════════════════════════════════════
      //  PACKAGE LIST
      // ══════════════════════════════════════════════

      var allPackages = [];

      async function loadPackagesNeedingReview() {
        document.getElementById('pkg-list-loading').classList.remove('hidden');
        document.getElementById('pkg-list-empty').classList.add('hidden');
        document.getElementById('pkg-list').innerHTML = '';

        try {
          var snapRes = await fetch(SUPABASE_URL + '/rest/v1/snapshots?select=package,version,created_at&order=created_at.desc&limit=500', { headers: anonHeaders() });
          var snaps = await snapRes.json();
          var advRes = await fetch(SUPABASE_URL + '/rest/v1/advisories?select=package,safe_versions', { headers: anonHeaders() });
          var advs = await advRes.json();
          if (!Array.isArray(advs)) advs = [];
          var advMap = {};
          advs.forEach(function(a) { advMap[a.package] = a; });

          var pkgMap = {};
          if (!Array.isArray(snaps)) snaps = [];
          snaps.forEach(function(s) {
            if (!pkgMap[s.package]) {
              pkgMap[s.package] = { name: s.package, latestVersion: s.version, latestDate: s.created_at, hasAdvisory: false, isCovered: false };
            }
          });
          Object.keys(advMap).forEach(function(pkg) {
            if (pkgMap[pkg]) {
              pkgMap[pkg].hasAdvisory = true;
              var sv = advMap[pkg].safe_versions || [];
              if (typeof sv === 'string') { try { sv = JSON.parse(sv); } catch(e) { sv = []; } }
              pkgMap[pkg].isCovered = Array.isArray(sv) && sv.indexOf(pkgMap[pkg].latestVersion) !== -1;
            }
          });

          allPackages = Object.values(pkgMap).filter(function(p) {
            return !p.hasAdvisory || !p.isCovered;
          }).map(function(p) {
            return { name: p.name, latestVersion: p.latestVersion, latestDate: p.latestDate, status: p.hasAdvisory ? 'stale' : 'none' };
          }).sort(function(a, b) { return a.name.localeCompare(b.name); });

          document.getElementById('pkg-list-loading').classList.add('hidden');
          if (allPackages.length === 0) document.getElementById('pkg-list-empty').classList.remove('hidden');
          renderPackageList(allPackages);
        } catch(e) {
          document.getElementById('pkg-list-loading').classList.add('hidden');
          document.getElementById('pkg-list-empty').textContent = 'Error: ' + e.message;
          document.getElementById('pkg-list-empty').classList.remove('hidden');
        }
      }

      function renderPackageList(pkgs) {
        var el = document.getElementById('pkg-list');
        if (pkgs.length === 0) { el.innerHTML = ''; document.getElementById('pkg-list-empty').classList.remove('hidden'); return; }
        document.getElementById('pkg-list-empty').classList.add('hidden');
        el.innerHTML = pkgs.map(function(p) {
          var statusLabel = p.status === 'none' ? 'No advisory' : 'Advisory outdated';
          var statusCls = p.status === 'none' ? 'status-none' : 'status-stale';
          var selectedCls = selectedPkg === p.name ? ' selected' : '';
          return '<div class="pkg-card' + selectedCls + '" data-pkg="' + p.name + '" onclick="selectReviewPackage(\'' + p.name.replace(/'/g, "\\'") + '\')">'
            + '<div class="flex items-center justify-between gap-2">'
            + '<span class="pkg-card-name">' + p.name + '</span>'
            + '<span class="pkg-card-status ' + statusCls + '">' + statusLabel + '</span>'
            + '</div>'
            + '<div class="pkg-card-version">v' + p.latestVersion + '</div>'
            + '</div>';
        }).join('');
      }

      document.getElementById('pkg-filter').addEventListener('input', function() {
        var q = this.value.trim().toLowerCase();
        renderPackageList(q ? allPackages.filter(function(p) { return p.name.toLowerCase().indexOf(q) !== -1; }) : allPackages);
      });

      window.selectReviewPackage = async function(pkgName) {
        selectedPkg = pkgName;
        document.querySelectorAll('.pkg-card').forEach(function(c) { c.classList.toggle('selected', c.dataset.pkg === pkgName); });
        document.getElementById('review-area').classList.remove('hidden');
        loadNotes(pkgName);
        document.getElementById('floating-notes-btn').classList.remove('hidden');
        document.getElementById('f-package').value = pkgName;
        document.getElementById('f-package-split').value = pkgName;
        await runAutoCompare(pkgName);
      };

      // ══════════════════════════════════════════════
      //  AUTOMATED COMPARE
      // ══════════════════════════════════════════════

      async function runAutoCompare(pkgName) {
        var loading = document.getElementById('auto-compare-loading');
        var loadingSplit = document.getElementById('auto-compare-loading-split');
        var error = document.getElementById('auto-compare-error');
        var errorSplit = document.getElementById('auto-compare-error-split');
        var result = document.getElementById('compare-result');
        var resultSplit = document.getElementById('compare-result-split');
        var controls = document.getElementById('manual-controls');
        var controlsSplit = document.getElementById('manual-controls-split');

        if (currentLayout === 'tabs') {
          loading.classList.remove('hidden'); error.classList.add('hidden'); result.classList.add('hidden'); controls.classList.add('hidden');
        } else {
          loadingSplit.classList.remove('hidden'); errorSplit.classList.add('hidden'); resultSplit.classList.add('hidden'); controlsSplit.classList.add('hidden');
        }

        try {
          var snapRes = await fetch(SUPABASE_URL + '/rest/v1/snapshots?select=*&package=eq.' + encodeURIComponent(pkgName) + '&order=version.desc', { headers: anonHeaders() });
          currentSnapshots = await snapRes.json();
          var aurRes = await fetch(API_PREFIX + '/aur/info/' + encodeURIComponent(pkgName));
          var aurData = await aurRes.json();

          if (aurData.resultcount === 0 && currentSnapshots.length === 0) {
            var errEl = currentLayout === 'tabs' ? error : errorSplit;
            errEl.textContent = 'Package not found in AUR or trust DB.';
            errEl.classList.remove('hidden');
            if (currentLayout === 'tabs') loading.classList.add('hidden'); else loadingSplit.classList.add('hidden');
            return;
          }

          currentPkgData = { name: pkgName, aurInfo: aurData.resultcount > 0 ? aurData.results[0] : null, snapshots: currentSnapshots, versions: [...new Set(currentSnapshots.map(function(s) { return s.version; }))] };
          if (currentPkgData.aurInfo && currentPkgData.versions.indexOf(currentPkgData.aurInfo.Version) === -1) currentPkgData.versions.push(currentPkgData.aurInfo.Version);
          currentPkgData.versions.sort();

          if (currentPkgData.versions.length < 2) {
            var errEl2 = currentLayout === 'tabs' ? error : errorSplit;
            errEl2.textContent = 'Only one version available — cannot compare.';
            errEl2.classList.remove('hidden');
            if (currentLayout === 'tabs') loading.classList.add('hidden'); else loadingSplit.classList.add('hidden');
            return;
          }

          var vOld = currentPkgData.versions[currentPkgData.versions.length - 2];
          var vNew = currentPkgData.versions[currentPkgData.versions.length - 1];
          var oldText = await fetchPkgbuild(pkgName, vOld, currentPkgData);
          var newText = await fetchPkgbuild(pkgName, vNew, currentPkgData);

          if (!oldText && !newText) {
            var errEl3 = currentLayout === 'tabs' ? error : errorSplit;
            errEl3.textContent = 'Could not fetch PKGBUILDs.';
            errEl3.classList.remove('hidden');
            if (currentLayout === 'tabs') loading.classList.add('hidden'); else loadingSplit.classList.add('hidden');
            return;
          }

          var diff = computeDiff(oldText || '', newText || '', vOld, vNew);
          var suspicious = detectSuspicious(newText || '');
          var advRes2 = await fetch(SUPABASE_URL + '/rest/v1/advisories?select=*&package=eq.' + encodeURIComponent(pkgName), { headers: anonHeaders() });
          var advisories = await advRes2.json();
          var advisory = advisories.length > 0 ? advisories[0] : null;
          var html = buildDiffHtml(diff, suspicious, advisory, { pkg: pkgName, vOld: vOld, vNew: vNew, oldText: oldText, newText: newText });

          if (currentLayout === 'tabs') { result.innerHTML = html; result.classList.remove('hidden'); controls.classList.remove('hidden'); loading.classList.add('hidden'); }
          else { resultSplit.innerHTML = html; resultSplit.classList.remove('hidden'); controlsSplit.classList.remove('hidden'); loadingSplit.classList.add('hidden'); }
        } catch(e) {
          var errEl4 = currentLayout === 'tabs' ? error : errorSplit;
          errEl4.textContent = 'Error: ' + e.message;
          errEl4.classList.remove('hidden');
          if (currentLayout === 'tabs') loading.classList.add('hidden'); else loadingSplit.classList.add('hidden');
        }
      }

      // ══════════════════════════════════════════════
      //  SHARED DIFF LOGIC
      // ══════════════════════════════════════════════

      async function fetchPkgbuild(pkg, version, data) {
        var snap = data.snapshots.find(function(s) { return s.version === version && s.pkgbuild_text; });
        if (snap && snap.pkgbuild_text) return snap.pkgbuild_text;
        if (data.aurInfo && data.aurInfo.Version === version) {
          try { var res = await fetch(API_PREFIX + '/aur/pkgbuild/' + encodeURIComponent(pkg)); var text = await res.text(); if (text && text.length > 10 && text.indexOf('#') !== -1) return text; } catch(e) {}
        }
        // Fallback: fetch from Arch GitLab via Worker proxy for official packages
        try { var glRes = await fetch(API_PREFIX + '/official/pkgbuild/' + encodeURIComponent(pkg)); if (glRes.ok) { var text = await glRes.text(); if (text && text.length > 10 && text.indexOf('#') !== -1) return text; } } catch(e) {}
        return null;
      }

      function computeDiff(oldText, newText) {
        var oldLines = oldText.split('\n'), newLines = newText.split('\n');
        var result = { lines: [], stats: { added: 0, removed: 0, unchanged: 0 } };
        var m = oldLines.length, n = newLines.length;
        var dp = Array.from({ length: m + 1 }, function() { return new Array(n + 1).fill(0); });
        for (var i = 1; i <= m; i++) for (var j = 1; j <= n; j++) dp[i][j] = oldLines[i-1] === newLines[j-1] ? dp[i-1][j-1] + 1 : Math.max(dp[i-1][j], dp[i][j-1]);
        var ii = m, jj = n, raw = [];
        while (ii > 0 || jj > 0) {
          if (ii > 0 && jj > 0 && oldLines[ii-1] === newLines[jj-1]) { raw.unshift({ type: 'ctx', text: oldLines[ii-1] }); result.stats.unchanged++; ii--; jj--; }
          else if (jj > 0 && (ii === 0 || dp[ii][jj-1] >= dp[ii-1][jj])) { raw.unshift({ type: 'add', text: newLines[jj-1] }); result.stats.added++; jj--; }
          else { raw.unshift({ type: 'del', text: oldLines[ii-1] }); result.stats.removed++; ii--; }
        }
        result.lines = raw; return result;
      }

      var SUSPICIOUS_PATTERNS = [
        { re: /curl\s+.*\|\s*(bash|sh)/i, label: 'curl pipe to shell', severity: 'high' },
        { re: /wget\s+.*\|\s*(sh|bash)/i, label: 'wget pipe to shell', severity: 'high' },
        { re: /\beval\b/i, label: 'eval usage', severity: 'high' },
        { re: /rm\s+-rf\s+[\/~]/i, label: 'Aggressive rm -rf', severity: 'high' },
        { re: /npm\s+install\s+.*\|\s*(bash|sh|node)/i, label: 'npm pipe to shell', severity: 'high' },
        { re: /npx\s+.*\|\s*(bash|sh)/i, label: 'npx pipe to shell', severity: 'high' },
        { re: /\\x[0-9a-f]{2}/i, label: 'Hex escape', severity: 'medium' },
        { re: /\bbase64\s+-d/i, label: 'Base64 decode', severity: 'medium' },
      ];

      function detectSuspicious(text) {
        var findings = [];
        text.split('\n').forEach(function(line, idx) {
          SUSPICIOUS_PATTERNS.forEach(function(p) { if (p.re.test(line)) findings.push({ line: idx + 1, label: p.label, severity: p.severity }); });
        });
        return findings;
      }

      function buildDiffHtml(diff, suspicious, advisory, ctx) {
        var identical = diff.stats.added === 0 && diff.stats.removed === 0;
        var html = '<div class="bg-surface border border-border rounded-xl p-6">';
        html += '<div class="flex flex-wrap items-center gap-3 mb-4"><h3 class="text-xl font-heading text-white">' + ctx.pkg + '</h3>';
        html += identical ? '<span class="verdict-badge verdict-clean">IDENTICAL</span>' : suspicious.length > 0 ? '<span class="verdict-badge verdict-advisory">CHANGES</span>' : '<span class="verdict-badge verdict-outdated">MODIFIED</span>';
        html += '</div>';
        html += '<div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-4 text-sm">';
        html += '<div><span class="text-muted-text">Old:</span> <span class="text-white">' + ctx.vOld + '</span></div>';
        html += '<div><span class="text-muted-text">New:</span> <span class="text-white">' + ctx.vNew + '</span></div>';
        html += '<div><span class="text-muted-text">Added:</span> <span class="text-green-400">+' + diff.stats.added + '</span></div>';
        html += '<div><span class="text-muted-text">Removed:</span> <span class="text-red-400">-' + diff.stats.removed + '</span></div></div>';
        if (advisory) html += '<div class="bg-red-900/20 border border-red-800 rounded-lg p-3 text-sm mb-4"><span class="text-red-400 font-bold">Advisory:</span> ' + advisory.severity.toUpperCase() + ' — ' + advisory.summary + '</div>';
        if (suspicious.length > 0) {
          html += '<div class="bg-yellow-900/20 border border-yellow-800 rounded-lg p-3 text-sm mb-4"><span class="text-yellow-400 font-bold">Suspicious (' + suspicious.length + '):</span><ul class="mt-1">';
          suspicious.forEach(function(s) { html += '<li class="text-xs">[' + s.severity.toUpperCase() + '] Line ' + s.line + ': ' + s.label + '</li>'; });
          html += '</ul></div>';
        }
        if (!identical) {
          html += '<div class="border border-border rounded-lg overflow-hidden"><div class="diff-hunk">@@ Diff: ' + ctx.vOld + ' → ' + ctx.vNew + ' @@</div>';
          diff.lines.forEach(function(line) { if (line.type === 'ctx') return; html += '<div class="diff-line ' + (line.type === 'add' ? 'diff-add' : 'diff-del') + '">' + (line.type === 'add' ? '+' : '-') + ' ' + escapeHtml(line.text) + '</div>'; });
          html += '</div>';
        } else {
          html += '<div class="text-center py-6 text-muted-text text-sm">Identical — no changes.</div>';
        }
        html += '</div>';
        return html;
      }

      function escapeHtml(t) { return t.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

      window.runManualCompare = function() { if (selectedPkg) runAutoCompare(selectedPkg); };

      // ══════════════════════════════════════════════
      //  AI Analysis
      // ══════════════════════════════════════════════

      async function runAiAnalysisBase(resultElId) {
        if (!currentPkgData || !selectedPkg) return;
        var vOld = currentPkgData.versions[currentPkgData.versions.length - 2];
        var vNew = currentPkgData.versions[currentPkgData.versions.length - 1];
        var resultEl = document.getElementById(resultElId);
        var oldText = await fetchPkgbuild(selectedPkg, vOld, currentPkgData);
        var newText = await fetchPkgbuild(selectedPkg, vNew, currentPkgData);
        resultEl.classList.remove('hidden');
        resultEl.innerHTML = '<div class="text-muted-text text-sm">Checking AI cache...</div>';
        try {
          var diffHash = await sha256((oldText || '') + '---' + (newText || ''));
          var cacheRes = await fetch(SUPABASE_URL + '/rest/v1/ai_analysis?select=*&package=eq.' + encodeURIComponent(selectedPkg) + '&version_old=eq.' + encodeURIComponent(vOld) + '&version_new=eq.' + encodeURIComponent(vNew) + '&diff_hash=eq.' + diffHash + '&expires_at=gt.' + new Date().toISOString(), { headers: anonHeaders() });
          var cached = await cacheRes.json();
          if (cached && cached.length > 0) { var parsed = cached[0].analysis; try { parsed = JSON.parse(parsed); } catch(e) {} renderAiResult(resultEl, parsed, cached[0].recommendation, true); return; }
          resultEl.innerHTML = '<div class="text-muted-text text-sm">Running AI analysis via NVIDIA NIM...</div>';
          var suspicious = detectSuspicious(newText || '');
          var aiRes = await fetch(WORKER_URL + '/cpac-trust-db/api/ai/analyze-diff', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ package: selectedPkg, version_old: vOld, version_new: vNew, old_pkgbuild: oldText || '', new_pkgbuild: newText || '', suspicious_patterns: suspicious }) });
          if (!aiRes.ok) { var errData = await aiRes.json().catch(function() { return { error: 'AI request failed' }; }); resultEl.innerHTML = '<div class="text-red-400 text-sm">AI failed: ' + (errData.error || 'Unknown') + '</div>'; return; }
          var analysis = await aiRes.json();
          renderAiResult(resultEl, analysis, analysis.recommendation || 'suspicious', false);
        } catch(e) { resultEl.innerHTML = '<div class="text-red-400 text-sm">AI failed: ' + e.message + '</div>'; }
      }

      window.runAiAnalysis = function() { runAiAnalysisBase('ai-result'); };
      window.runAiAnalysisSplit = function() { runAiAnalysisBase('ai-result-split'); };

      function renderAiResult(el, analysis, recommendation, fromCache) {
        var rec = recommendation || 'suspicious';
        if (typeof analysis === 'string') {
          el.innerHTML = '<div class="bg-surface border border-border rounded-lg p-4"><div class="flex items-center gap-2 mb-2"><span class="ai-badge ai-' + rec + '">' + rec.toUpperCase() + '</span><span class="text-xs text-muted-text">' + (fromCache ? '(cached)' : '(fresh)') + '</span></div><p class="text-sm text-muted-text">' + (analysis || '').replace(/</g,'&lt;') + '</p></div>';
          return;
        }
        var html = '<div class="bg-surface border border-border rounded-lg p-4">';
        html += '<div class="flex items-center gap-2 mb-3"><span class="ai-badge ai-' + rec + '">' + rec.toUpperCase() + '</span><span class="text-xs text-muted-text">' + (fromCache ? '(cached)' : '(fresh via NVIDIA NIM)') + '</span></div>';
        if (analysis.analysis) html += '<p class="text-sm text-muted-text mb-3">' + (analysis.analysis || '').replace(/</g,'&lt;') + '</p>';
        if (analysis.summary) html += '<div class="bg-base border border-border rounded-lg p-3 text-sm mb-2"><span class="text-ember-core font-bold">Advisory:</span> <span class="text-white">' + (analysis.summary || '').replace(/</g,'&lt;') + '</span></div>';
        if (analysis.advisory_severity && analysis.advisory_severity !== 'none') html += '<div class="text-xs text-muted-text mb-2">Severity: <span class="text-white font-bold">' + analysis.advisory_severity.toUpperCase() + '</span></div>';
        if (analysis.affected_versions && analysis.affected_versions.length) html += '<div class="text-xs text-muted-text mb-2">Affected: <span class="text-white">' + analysis.affected_versions.join(', ') + '</span></div>';
        if (analysis.safe_versions && analysis.safe_versions.length) html += '<div class="text-xs text-muted-text">Safe: <span class="text-white">' + analysis.safe_versions.join(', ') + '</span></div>';
        html += '</div>';
        el.innerHTML = html;
      }

      // ══════════════════════════════════════════════
      //  NOTES
      // ══════════════════════════════════════════════

      window.toggleNotes = function() {
        notesVisible = !notesVisible;
        document.getElementById('notes-overlay').classList.toggle('hidden', !notesVisible);
        document.getElementById('floating-notes-btn').classList.toggle('hidden', notesVisible);
        if (notesVisible) { document.getElementById('notes-pkg-name').textContent = selectedPkg || '—'; document.getElementById('notes-textarea').focus(); }
      };

      function loadNotes(pkgName) {
        document.getElementById('notes-textarea').value = localStorage.getItem('cpac-notes-' + pkgName) || '';
        document.getElementById('notes-pkg-name').textContent = pkgName;
      }

      document.getElementById('notes-textarea').addEventListener('input', function() {
        if (selectedPkg) localStorage.setItem('cpac-notes-' + selectedPkg, this.value);
      });

      // ══════════════════════════════════════════════
      //  SUBMIT FORMS
      // ══════════════════════════════════════════════

      function handleSubmit(suffix) {
        document.getElementById('publish-form' + suffix).addEventListener('submit', async function(e) {
          e.preventDefault();
          var errorEl = document.getElementById('submit-error' + suffix);
          var successEl = document.getElementById('submit-success' + suffix);
          var btn = document.getElementById('submitBtn' + suffix);
          errorEl.classList.add('hidden'); successEl.classList.add('hidden');
          btn.textContent = 'Submitting...'; btn.disabled = true;
          var cs = function(v) { return v ? v.split(',').map(function(s) { return s.trim(); }).filter(Boolean) : []; };
          var body = { p_package: document.getElementById('f-package' + suffix).value.trim(), p_severity: document.getElementById('f-severity' + suffix).value, p_status: document.getElementById('f-status' + suffix).value, p_summary: document.getElementById('f-summary' + suffix).value.trim(), p_description: document.getElementById('f-description' + suffix).value.trim(), p_affected_versions: JSON.stringify(cs(document.getElementById('f-affected' + suffix).value)), p_safe_versions: JSON.stringify(cs(document.getElementById('f-safe' + suffix).value)), p_reference_urls: JSON.stringify(cs(document.getElementById('f-urls' + suffix).value)), p_cve: document.getElementById('f-cve' + suffix).value.trim() };
          try {
            var res = await fetch(SUPABASE_URL + '/rest/v1/rpc/direct_publish_advisory', { method: 'POST', headers: authHeaders(), body: JSON.stringify(body) });
            var txt = await res.text(); var data = txt ? JSON.parse(txt) : {};
            if (res.ok) { successEl.textContent = 'Advisory published directly.'; successEl.classList.remove('hidden'); document.getElementById('publish-form' + suffix).reset(); if (selectedPkg) localStorage.removeItem('cpac-notes-' + selectedPkg); loadPublished(); loadStats(); loadPackagesNeedingReview(); }
            else { errorEl.textContent = data.message || data.error || 'Failed (status ' + res.status + ').'; errorEl.classList.remove('hidden'); }
          } catch(err) { errorEl.textContent = 'Network error: ' + err.message; errorEl.classList.remove('hidden'); }
          btn.textContent = 'Submit Advisory'; btn.disabled = false;
        });
      }
      handleSubmit(''); handleSubmit('-split');

      // ── Load pending ──
      function loadPending() {
        fetch(SUPABASE_URL + '/rest/v1/pending_advisories?select=*,profiles:submitted_by(display_name)&review_status=eq.pending&order=created_at.asc', {
          headers: authHeaders()
        }).then(function(r) { return r.json(); }).then(function(data) {
          document.getElementById('pending-loading').classList.add('hidden');
          document.getElementById('pending-count').textContent = data.length;
          if (data.length === 0) { document.getElementById('pending-empty').classList.remove('hidden'); return; }
          var html = data.map(function(s) {
            var submitter = s.profiles ? s.profiles.display_name : 'Unknown';
            return '<div class="pending-card" id="pending-' + s.id + '">'
              + '<div class="flex flex-wrap items-center gap-2 mb-2">'
              + '<h3 class="text-lg font-heading text-white">' + s.package + '</h3>'
              + '<span class="severity-badge severity-' + s.severity + '">' + s.severity + '</span>'
              + '<span class="status-badge status-' + s.status + '">' + s.status + '</span>'
              + '<span class="text-xs text-muted-text ml-auto">by ' + submitter + ' — ' + new Date(s.created_at).toLocaleDateString() + '</span>'
              + '</div>'
              + '<p class="text-sm text-muted-text mb-3">' + s.summary + '</p>'
              + (s.description ? '<p class="text-xs text-muted-text mb-3 whitespace-pre-line">' + s.description + '</p>' : '')
              + (s.cve ? '<div class="text-xs text-muted-text mb-2">CVE: <span class="text-white">' + s.cve + '</span></div>' : '')
              + '<div class="flex gap-2 mt-3">'
              + '<button onclick="approveAdvisory(\'' + s.id + '\')" class="action-btn bg-green-800 hover:bg-green-700 text-green-100">Approve</button>'
              + '<button onclick="rejectAdvisory(\'' + s.id + '\')" class="action-btn bg-red-800 hover:bg-red-700 text-red-100">Reject</button>'
              + '</div>'
              + '<div id="action-msg-' + s.id + '" class="hidden text-xs mt-2"></div>'
              + '</div>';
          }).join('');
          document.getElementById('pending-list').innerHTML = html;
        });
      }

      window.approveAdvisory = async function(id) {
        var msgEl = document.getElementById('action-msg-' + id);
        msgEl.className = 'text-xs mt-2 text-green-400'; msgEl.textContent = 'Approving...';
        try {
          var res = await fetch(SUPABASE_URL + '/rest/v1/rpc/approve_advisory', { method: 'POST', headers: authHeaders(), body: JSON.stringify({ p_pending_id: id, p_reviewed_by: currentUser.id, p_review_notes: '' }) });
          if (res.ok) { msgEl.textContent = 'Approved!'; setTimeout(function() { loadPending(); loadPublished(); loadStats(); loadPackagesNeedingReview(); }, 1000); }
          else { msgEl.className = 'text-xs mt-2 text-red-400'; msgEl.textContent = 'Error: ' + await res.text(); }
        } catch(e) { msgEl.className = 'text-xs mt-2 text-red-400'; msgEl.textContent = e.message; }
      };

      window.rejectAdvisory = async function(id) {
        var notes = prompt('Rejection reason (optional):');
        var msgEl = document.getElementById('action-msg-' + id);
        msgEl.className = 'text-xs mt-2 text-yellow-400'; msgEl.textContent = 'Rejecting...';
        try {
          var res = await fetch(SUPABASE_URL + '/rest/v1/rpc/reject_advisory', { method: 'POST', headers: authHeaders(), body: JSON.stringify({ p_pending_id: id, p_reviewed_by: currentUser.id, p_review_notes: notes || '' }) });
          if (res.ok) { msgEl.textContent = 'Rejected.'; setTimeout(function() { loadPending(); loadStats(); }, 1000); }
          else { msgEl.className = 'text-xs mt-2 text-red-400'; msgEl.textContent = 'Error: ' + await res.text(); }
        } catch(e) { msgEl.className = 'text-xs mt-2 text-red-400'; msgEl.textContent = e.message; }
      };

      // ── Load published ──
      function loadPublished() {
        fetch(SUPABASE_URL + '/rest/v1/advisories?select=*&order=updated.desc', { headers: anonHeaders() })
          .then(function(r) { return r.json(); }).then(function(data) {
            document.getElementById('published-loading').classList.add('hidden');
            document.getElementById('published-list').innerHTML = data.map(function(a) {
              return '<div class="pending-card"><div class="flex flex-wrap items-center gap-2 mb-1"><span class="text-white font-bold">' + a.package + '</span><span class="severity-badge severity-' + a.severity + '">' + a.severity + '</span><span class="status-badge status-' + a.status + '">' + a.status + '</span></div><p class="text-sm text-muted-text">' + a.summary + '</p><div class="text-xs text-muted-text mt-1">By ' + a.reported_by + ' — ' + a.reported + '</div></div>';
            }).join('');
          });
      }

      // ── Stats ──
      function loadStats() {
        var today = new Date().toISOString().split('T')[0];
        Promise.all([
          fetch(SUPABASE_URL + '/rest/v1/advisories?select=id', { headers: anonHeaders() }).then(function(r) { return r.json(); }),
          fetch(SUPABASE_URL + '/rest/v1/pending_advisories?select=id&review_status=eq.pending', { headers: anonHeaders() }).then(function(r) { return r.json(); }),
          fetch(SUPABASE_URL + '/rest/v1/pending_advisories?select=id&review_status=eq.approved&reviewed_at=gte.' + today + 'T00:00:00', { headers: anonHeaders() }).then(function(r) { return r.json(); }),
          fetch(SUPABASE_URL + '/rest/v1/pending_advisories?select=id&review_status=eq.rejected&reviewed_at=gte.' + today + 'T00:00:00', { headers: anonHeaders() }).then(function(r) { return r.json(); })
        ]).then(function(results) {
          document.getElementById('stat-total').textContent = results[0].length;
          document.getElementById('stat-pending').textContent = results[1].length;
          document.getElementById('stat-approved').textContent = results[2].length;
          document.getElementById('stat-rejected').textContent = results[3].length;
        });
      }

      // ── Volunteers ──
      function loadVolunteers() {
        fetch(SUPABASE_URL + '/rest/v1/volunteer_reputation?select=*&order=total_submissions.desc', { headers: anonHeaders() })
          .then(function(r) { return r.json(); }).then(function(data) {
            document.getElementById('vol-loading').classList.add('hidden');
            if (!data || data.length === 0) { document.getElementById('vol-empty').classList.remove('hidden'); return; }
            document.getElementById('vol-list').innerHTML = data.map(function(v) {
              var tierClass = 'tier-' + (v.trust_tier || 'standard');
              var strikesColor = (v.strikes || 0) >= 2 ? 'text-red-400' : (v.strikes || 0) >= 1 ? 'text-yellow-400' : 'text-muted-text';
              return '<div class="vol-card"><div class="flex flex-wrap items-center gap-4">'
                + '<div class="min-w-[140px]"><span class="text-white font-bold">' + (v.display_name || 'Unknown') + '</span></div>'
                + '<div><span class="tier-badge ' + tierClass + '">' + (v.trust_tier || 'standard') + '</span></div>'
                + '<div class="text-sm"><span class="text-muted-text">Rate:</span> <span class="text-white">' + (v.approval_rate || 0) + '%</span></div>'
                + '<div class="text-sm"><span class="text-muted-text">Submitted:</span> <span class="text-white">' + (v.total_submissions || 0) + '</span></div>'
                + '<div class="text-sm"><span class="text-muted-text">Approved:</span> <span class="text-green-400">' + (v.approved || 0) + '</span></div>'
                + '<div class="text-sm"><span class="text-muted-text">Rejected:</span> <span class="text-red-400">' + (v.rejected || 0) + '</span></div>'
                + '<div class="text-sm"><span class="text-muted-text">Strikes:</span> <span class="' + strikesColor + '">' + (v.strikes || 0) + '</span></div>'
                + '</div></div>';
            }).join('');
          });
      }

      document.getElementById('logoutBtn').addEventListener('click', function() {
        supabase.auth.signOut().then(function() { window.location.href = '/cpac-trust-db/web/panel/login/'; });
      });
    })();
  </script>
</MainLayout>
