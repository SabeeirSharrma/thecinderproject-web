---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Donate" description="Support The Cinder Project — keep the open-source tools running.">
  <div class="container mx-auto px-4 py-16 max-w-xl">

    <!-- Header -->
    <header class="mb-12 text-center">
      <div class="flex items-center justify-center gap-2 text-xs font-bold tracking-widest uppercase text-ember-core mb-3 anim-slide-up">
        <svg class="w-4 h-4" viewBox="0 0 16 16" fill="none">
          <path d="M8 2C8 2 5 5 5 8.5C5 10.4 6.3 12 8 12C9.7 12 11 10.4 11 8.5C11 5.5 8 2 8 2Z" fill="currentColor"/>
          <path d="M8 6.5C8 6.5 6.5 8 6.5 9.5C6.5 10.3 7.2 11 8 11C8.8 11 9.5 10.3 9.5 9.5C9.5 8 8 6.5 8 6.5Z" fill="#FFD4B8"/>
        </svg>
        Support open source
      </div>
      <h1 class="text-4xl md:text-5xl font-heading text-white mb-4 uppercase tracking-widest anim-slide-up delay-2">Keep the cinders burning</h1>
      <p class="text-lg text-muted-text leading-relaxed anim-slide-up delay-3">
        The Cinder Project builds free, open-source tools like <a href="/cpac" class="text-ember-light hover:text-ember-core transition-colors">CPAC</a> and CinderOS. Your support helps keep the servers on and the code flowing.
      </p>
    </header>

    <!-- Amount Selection -->
    <section class="mb-8 reveal">
      <label class="block text-xs font-bold tracking-widest uppercase text-muted-text mb-3">Choose an amount</label>
      <div class="grid grid-cols-4 gap-2 mb-3">
        <button class="amt-btn" data-amount="50">₹50</button>
        <button class="amt-btn" data-amount="100">₹100</button>
        <button class="amt-btn" data-amount="250">₹250</button>
        <button class="amt-btn active" data-amount="500">₹500</button>
      </div>
      <div class="relative">
        <span class="absolute left-4 top-1/2 -translate-y-1/2 text-muted-text pointer-events-none">₹</span>
        <input
          class="custom-input"
          type="number"
          id="customAmt"
          placeholder="Custom amount"
          min="1"
        />
      </div>
    </section>

    <!-- Payment Gateway -->
    <section class="mb-8 reveal stagger-1">
      <label class="block text-xs font-bold tracking-widest uppercase text-muted-text mb-3">Pay with</label>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">

        <button class="gw-btn" id="upiBtn">
          <div class="gw-icon upi">
            <svg width="22" height="22" viewBox="0 0 22 22" fill="none">
              <path d="M4 11L11 4L18 11L11 18L4 11Z" fill="#00B9F1" opacity="0.9"/>
              <path d="M8 11L11 8L14 11L11 14L8 11Z" fill="#fff" opacity="0.9"/>
            </svg>
          </div>
          <div class="gw-name">UPI</div>
          <div class="gw-sub">GPay, PhonePe, Paytm, any UPI app</div>
        </button>

        <button class="gw-btn opacity-50 cursor-default" disabled>
          <div class="gw-icon rzp">
            <svg width="22" height="22" viewBox="0 0 22 22" fill="none">
              <path d="M6 16L10 6H14L16 16H13L12.5 13.5H9.5L9 16H6Z" fill="#1D63FF"/>
              <path d="M10 11.5L10.5 8.5H11.5L12 11.5H10Z" fill="#fff" opacity="0.6"/>
            </svg>
          </div>
          <div class="gw-name">Other options (via RazorPay)</div>
          <div class="gw-sub">Cards &amp; netbanking — coming soon</div>
        </button>

      </div>
    </section>

    <!-- Footer Note -->
    <p class="text-center text-xs text-muted-text leading-relaxed reveal stagger-2">
      All payments go directly to the project maintainer.<br>
      No fees deducted on UPI.
    </p>

  </div>

  <!-- UPI Modal -->
  <div class="modal-overlay" id="upiModal">
    <div class="modal">
      <button class="modal-close" id="modalClose">&times;</button>
      <div class="modal-title">Pay via UPI</div>
      <div class="modal-amt" id="modalAmt">₹500</div>

      <!-- QR Code (generated dynamically) -->
      <div class="qr-wrap">
        <div id="qrContainer" style="width:180px;height:180px;"></div>
      </div>

      <!-- UPI ID with copy -->
      <div class="upi-id-row">
        <div class="upi-id" id="upiIdDisplay">7211170000@fam</div>
        <button class="copy-btn" id="copyUpiBtn" title="Copy UPI ID">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
            <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
          </svg>
          <span id="copyLabel">Copy</span>
        </button>
      </div>

      <!-- Desktop: copy full UPI string -->
      <button class="copy-full-btn" id="copyFullBtn">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
          <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
        </svg>
        Copy UPI payment string
      </button>

      <!-- Mobile: open UPI app -->
      <a class="open-app-btn" id="openAppLink" href="#">
        Open UPI app
      </a>

      <!-- Desktop hint -->
      <div class="upi-hint desktop-hint">
        Open your UPI app on your phone and scan the QR code, or copy the UPI ID and pay manually.
      </div>
      <!-- Mobile hint -->
      <div class="upi-hint mobile-hint">
        Scan with any UPI app — GPay, PhonePe, Paytm, BHIM, etc.
      </div>
    </div>
  </div>
</MainLayout>

<style>
  /* Amount buttons */
  .amt-btn {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 10px;
    color: var(--color-muted-text);
    font-size: 15px;
    font-weight: 600;
    font-family: var(--font-heading);
    letter-spacing: 0.05em;
    padding: 0.75rem 0;
    cursor: pointer;
    transition: all 0.15s;
  }
  .amt-btn:hover {
    border-color: var(--color-ember-core);
    color: var(--color-ember-core);
    background: rgba(255, 69, 0, 0.08);
  }
  .amt-btn.active {
    border-color: var(--color-ember-core);
    color: var(--color-ember-core);
    background: rgba(255, 69, 0, 0.08);
  }

  /* Custom input */
  .custom-input {
    width: 100%;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 10px;
    color: var(--color-primary-text);
    font-size: 15px;
    font-family: var(--font-body);
    padding: 0.75rem 1rem 0.75rem 2.25rem;
    outline: none;
    transition: border-color 0.15s;
  }
  .custom-input::placeholder { color: var(--color-muted-text); opacity: 0.5; }
  .custom-input:focus { border-color: var(--color-ember-core); }

  /* Gateway buttons */
  .gw-btn {
    border-radius: 16px;
    padding: 1rem;
    cursor: pointer;
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    display: flex;
    flex-direction: column;
    gap: 6px;
    align-items: flex-start;
    transition: all 0.15s;
    font-family: inherit;
    text-align: left;
  }
  .gw-btn:not([disabled]):hover {
    border-color: var(--color-ember-core);
    background: rgba(255, 69, 0, 0.08);
  }
  .gw-icon {
    width: 36px;
    height: 36px;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 2px;
  }
  .gw-icon.rzp { background: rgba(29, 99, 255, 0.09); }
  .gw-icon.upi { background: rgba(0, 185, 241, 0.09); }
  .gw-name {
    font-size: 14px;
    font-weight: 600;
    font-family: var(--font-heading);
    color: var(--color-primary-text);
    line-height: 1;
  }
  .gw-sub {
    font-size: 12px;
    color: var(--color-muted-text);
    line-height: 1.3;
  }

  /* Modal */
  .modal-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.8);
    z-index: 100;
    align-items: center;
    justify-content: center;
    padding: 1rem;
  }
  .modal-overlay.open { display: flex; }

  .modal {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 16px;
    padding: 2rem;
    max-width: 380px;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
    position: relative;
  }
  .modal-close {
    position: absolute;
    top: 1rem;
    right: 1rem;
    background: none;
    border: none;
    color: var(--color-muted-text);
    cursor: pointer;
    font-size: 24px;
    line-height: 1;
    padding: 2px 6px;
    border-radius: 6px;
    transition: background 0.1s;
  }
  .modal-close:hover { background: var(--color-card); }

  .modal-title {
    font-size: 17px;
    font-weight: 700;
    font-family: var(--font-heading);
    color: var(--color-primary-text);
    text-align: center;
  }
  .modal-amt {
    font-size: 28px;
    font-weight: 700;
    color: var(--color-ember-core);
    letter-spacing: -0.03em;
  }
  .qr-wrap {
    background: var(--color-base);
    border: 1px solid var(--color-border);
    border-radius: 10px;
    padding: 1rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .qr-wrap canvas { display: block; width: 180px; height: 180px; }
  .qr-wrap img { display: block; width: 180px; height: 180px; }

  /* UPI ID row */
  .upi-id-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .upi-id {
    font-size: 13px;
    color: var(--color-muted-text);
    font-family: 'SF Mono', 'Fira Code', monospace;
    background: var(--color-card);
    border: 1px solid var(--color-border);
    border-radius: 6px;
    padding: 0.4rem 0.75rem;
    letter-spacing: 0.02em;
  }
  .copy-btn {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    background: var(--color-card);
    border: 1px solid var(--color-border);
    border-radius: 6px;
    padding: 0.4rem 0.6rem;
    color: var(--color-muted-text);
    cursor: pointer;
    font-size: 12px;
    font-family: var(--font-body);
    transition: all 0.15s;
  }
  .copy-btn:hover {
    border-color: var(--color-ember-core);
    color: var(--color-ember-core);
  }
  .copy-btn.copied {
    border-color: #4ade80;
    color: #4ade80;
  }

  /* Copy full UPI string button */
  .copy-full-btn {
    width: 100%;
    background: var(--color-card);
    color: var(--color-muted-text);
    border: 1px solid var(--color-border);
    border-radius: 10px;
    font-size: 13px;
    font-weight: 600;
    font-family: var(--font-body);
    padding: 0.6rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    transition: all 0.15s;
  }
  .copy-full-btn:hover {
    border-color: var(--color-ember-core);
    color: var(--color-ember-core);
  }
  .copy-full-btn.copied {
    border-color: #4ade80;
    color: #4ade80;
  }

  .upi-hint {
    font-size: 12px;
    color: var(--color-muted-text);
    opacity: 0.5;
    text-align: center;
    line-height: 1.5;
  }

  /* Show/hide hints based on device */
  .desktop-hint { display: none; }
  .mobile-hint { display: block; }

  @media (hover: hover) and (pointer: fine) {
    .desktop-hint { display: block; }
    .mobile-hint { display: none; }
  }

  .open-app-btn {
    width: 100%;
    background: var(--color-ember-core);
    color: #fff;
    border: none;
    border-radius: 10px;
    font-size: 15px;
    font-weight: 600;
    font-family: var(--font-heading);
    letter-spacing: 0.05em;
    padding: 0.85rem;
    cursor: pointer;
    transition: background 0.15s;
    text-decoration: none;
    display: block;
    text-align: center;
  }
  .open-app-btn:hover { background: var(--color-ember-deep); }

  /* Hide "Open UPI app" on desktop (no UPI apps there) */
  @media (hover: hover) and (pointer: fine) {
    .open-app-btn { display: none; }
  }

  @media (max-width: 480px) {
    .gw-btn { grid-column: span 1; }
  }
</style>

<script is:inline>
  // Load QR library then init
  (function() {
    var script = document.createElement('script');
    script.src = 'https://cdn.jsdelivr.net/npm/qrcodejs@1.0.0/qrcode.min.js';
    script.onload = initDonate;
    document.head.appendChild(script);

    function initDonate() {
      var selectedAmt = 500;

      function buildUpiString(amt) {
        var vpa = '7211170000@fam';
        var name = 'The Cinder Project';
        return 'upi://pay?pa=' + encodeURIComponent(vpa) + '&pn=' + encodeURIComponent(name) + '&am=' + amt + '&cu=INR&tn=' + encodeURIComponent('Donation - The Cinder Project');
      }

      function getAmt() {
        var custom = document.getElementById('customAmt');
        if (custom && custom.value && parseInt(custom.value) > 0) return parseInt(custom.value);
        return selectedAmt;
      }

      function generateQR(amt) {
        var container = document.getElementById('qrContainer');
        if (!container) return;
        container.innerHTML = '';
        try {
          new QRCode(container, {
            text: buildUpiString(amt),
            width: 180,
            height: 180,
            colorDark: '#FFFFFF',
            colorLight: '#111111',
            correctLevel: QRCode.CorrectLevel.M,
          });
        } catch (e) {
          console.error('QR generation failed:', e);
          container.innerHTML = '<p style="color:#aaa;text-align:center;font-size:12px;padding:2rem;">QR unavailable</p>';
        }
      }

      // Amount buttons
      document.querySelectorAll('.amt-btn').forEach(function(btn) {
        btn.addEventListener('click', function() {
          document.querySelectorAll('.amt-btn').forEach(function(b) { b.classList.remove('active'); });
          btn.classList.add('active');
          selectedAmt = parseInt(btn.getAttribute('data-amount') || '500');
          var custom = document.getElementById('customAmt');
          if (custom) custom.value = '';
        });
      });

      // Custom input
      var customInput = document.getElementById('customAmt');
      if (customInput) {
        customInput.addEventListener('input', function() {
          document.querySelectorAll('.amt-btn').forEach(function(b) { b.classList.remove('active'); });
          selectedAmt = parseInt(customInput.value) || 0;
        });
      }

      // Modal
      var upiBtn = document.getElementById('upiBtn');
      var modal = document.getElementById('upiModal');
      var modalClose = document.getElementById('modalClose');
      var modalAmt = document.getElementById('modalAmt');
      var openAppLink = document.getElementById('openAppLink');
      var copyUpiBtn = document.getElementById('copyUpiBtn');
      var copyFullBtn = document.getElementById('copyFullBtn');

      function openUPI() {
        var amt = getAmt();
        if (!amt || amt < 1) { alert('Please select or enter an amount first.'); return; }
        if (modalAmt) modalAmt.textContent = '\u20B9' + amt;
        generateQR(amt);
        if (openAppLink) openAppLink.href = buildUpiString(amt);
        if (modal) modal.classList.add('open');
      }

      function closeModal() {
        if (modal) modal.classList.remove('open');
      }

      function copyText(text, btn, label) {
        navigator.clipboard.writeText(text).then(function() {
          btn.classList.add('copied');
          if (label) label.textContent = 'Copied!';
          setTimeout(function() { btn.classList.remove('copied'); if (label) label.textContent = 'Copy'; }, 2000);
        }).catch(function() {
          var ta = document.createElement('textarea');
          ta.value = text;
          document.body.appendChild(ta);
          ta.select();
          document.execCommand('copy');
          document.body.removeChild(ta);
          btn.classList.add('copied');
          if (label) label.textContent = 'Copied!';
          setTimeout(function() { btn.classList.remove('copied'); if (label) label.textContent = 'Copy'; }, 2000);
        });
      }

      if (upiBtn) upiBtn.addEventListener('click', openUPI);
      if (modalClose) modalClose.addEventListener('click', closeModal);
      if (modal) modal.addEventListener('click', function(e) { if (e.target === modal) closeModal(); });
      document.addEventListener('keydown', function(e) { if (e.key === 'Escape') closeModal(); });

      if (copyUpiBtn) {
        copyUpiBtn.addEventListener('click', function() {
          copyText('7211170000@fam', copyUpiBtn, document.getElementById('copyLabel'));
        });
      }
      if (copyFullBtn) {
        copyFullBtn.addEventListener('click', function() {
          copyText(buildUpiString(getAmt()), copyFullBtn, null);
        });
      }
    }
  })();
</script>
