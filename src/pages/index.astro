---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Home">
  <!-- Hero Section -->
  <section class="relative min-h-[70vh] flex flex-col justify-center items-center text-center px-4 overflow-hidden">
    <!-- Animated ember glow background -->
    <div class="absolute inset-0 z-0 opacity-20 pointer-events-none ember-glow-bg"></div>
    
    <!-- Floating ember particles -->
    <div class="absolute bottom-0 inset-x-0 h-32 z-0 pointer-events-none">
      <span class="ember-particle"></span>
      <span class="ember-particle"></span>
      <span class="ember-particle"></span>
      <span class="ember-particle"></span>
      <span class="ember-particle"></span>
    </div>

    <div class="z-10 max-w-4xl">
      <h1 class="text-5xl md:text-7xl font-heading mb-6 tracking-wider anim-slide-up">
        <span class="text-white">The </span><span class="text-shimmer">Cinder</span><span class="text-white"> Project</span>
      </h1>
      <p class="text-xl md:text-2xl text-muted-text mb-10 max-w-2xl mx-auto anim-slide-up delay-2">
        Burn All the Blind Spots
      </p>
      <div class="flex flex-col sm:flex-row justify-center gap-4 anim-slide-up delay-3">
        <a href="#projects" class="btn-primary">Featured Projects</a>
        <a href="https://discord.gg/3ZMtEgJjFT" target="_blank" rel="noopener noreferrer" class="btn-secondary">Join Discord</a>
      </div>
    </div>
  </section>

  <!-- Mission Section -->
  <section class="py-20 bg-surface border-y border-border">
    <div class="container mx-auto px-4 text-center max-w-3xl reveal">
      <h2 class="text-3xl font-heading text-white mb-6 uppercase tracking-widest heading-line">Our Mission</h2>
      <p class="text-lg text-muted-text leading-relaxed">
        The Cinder Project develops and maintains open-source software with a focus on stability, transparency, and long-term maintainability.
      </p>
    </div>
  </section>

  <!-- Featured Projects -->
  <section id="projects" class="py-24 container mx-auto px-4">
    <h2 class="text-4xl font-heading text-white mb-12 text-center uppercase tracking-widest reveal heading-line">Featured Projects</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-5xl mx-auto">
      
      <!-- CPAC Card -->
      <div class="card group relative overflow-hidden reveal stagger-1">
        <div class="absolute top-0 right-0 w-32 h-32 bg-deep-red rounded-bl-full opacity-10 group-hover:opacity-30 transition-opacity duration-500"></div>
        <h3 class="text-2xl font-heading text-white mb-4">CPAC</h3>
        <p class="text-muted-text mb-8">
          Community Package Analysis Client: a package trust layer for Arch-based Linux distributions. CPAC is an advisor, not a package manager replacement. It helps answer whether a package looks trustworthy before you install it. Gives you trust and makes you think, "Is this truly safe to install?".
        </p>
        <div class="flex gap-4 relative z-20">
          <a href="/cpac" class="btn-primary text-sm px-4 py-2">CPAC Page</a>
          <a href="/cpac/docs" class="btn-secondary text-sm px-4 py-2">Docs</a>
        </div>
      </div>

      <!-- GitFlare Card -->
      <div class="card group relative overflow-hidden reveal stagger-2">
        <div class="absolute top-0 right-0 w-32 h-32 bg-ember-core rounded-bl-full opacity-10 group-hover:opacity-30 transition-opacity duration-500"></div>
        <h3 class="text-2xl font-heading text-white mb-4">GitFlare</h3>
        <p class="text-muted-text mb-8">
          GitFlare is a lean, self-hosted Git server built in Python. It sits as a thin layer on top of Git's own tooling — delegating all object storage and protocol handling to Git itself, while providing auth, repo management, and (eventually) a web UI on top.
        </p>
        <div class="flex gap-4 relative z-20">
          <a href="/gitflare" class="btn-primary text-sm px-4 py-2">GitFlare Page</a>
          <a href="/gitflare/docs" class="btn-secondary text-sm px-4 py-2">Docs</a>
        </div>
      </div>

    </div>
    <div class="text-center mt-10">
      <a href="/projects" class="btn-secondary text-sm px-6 py-2">View All Projects</a>
    </div>
  </section>

  <!-- Roadmap Preview -->
  <section class="py-20 bg-surface border-y border-border">
    <div class="container mx-auto px-4 max-w-4xl">
      <h2 class="text-3xl font-heading text-white mb-10 text-center uppercase tracking-widest reveal heading-line">Roadmap Preview</h2>
      
      <div class="space-y-6">
        <div class="flex items-center gap-6 bg-base p-6 rounded-lg border border-border reveal-left stagger-1">
          <div class="w-16 h-16 bg-cinder-mid flex items-center justify-center rounded text-white font-heading text-xl flex-shrink-0">1</div>
          <div>
            <h4 class="text-xl font-heading text-white">CPAC</h4>
            <p class="text-muted-text">Initial stable release</p>
          </div>
        </div>

        <div class="flex items-center gap-6 bg-base p-6 rounded-lg border border-border reveal-left stagger-1">
          <div class="w-16 h-16 bg-cinder-mid flex items-center justify-center rounded text-white font-heading text-xl flex-shrink-0">2</div>
          <div>
            <h4 class="text-xl font-heading text-white">GitFlare</h4>
            <p class="text-muted-text">Self hosted git server</p>
          </div>
        </div>

        <div class="flex items-center gap-6 bg-base p-6 rounded-lg border border-border reveal-left stagger-1">
          <div class="w-16 h-16 bg-cinder-mid flex items-center justify-center rounded text-white font-heading text-xl flex-shrink-0">3</div>
          <div>
            <h4 class="text-xl font-heading text-white">CinderBlock</h4>
            <p class="text-muted-text">Fork of uBlock origin - less bloated, no trackers, more stable</p>
          </div>
        </div>

        <div class="flex items-center gap-6 bg-base p-6 rounded-lg border border-border reveal-left stagger-1">
          <div class="w-16 h-16 bg-cinder-mid flex items-center justify-center rounded text-white font-heading text-xl flex-shrink-0">4</div>
          <div>
            <h4 class="text-xl font-heading text-white">CoalBox</h4>
            <p class="text-muted-text">Secure Password manager and TOTP (2FA) authenticator</p>
          </div>
        </div>

        <div class="flex items-center gap-6 bg-base p-6 rounded-lg border border-border reveal-left stagger-1">
          <div class="w-16 h-16 bg-cinder-mid flex items-center justify-center rounded text-white font-heading text-xl flex-shrink-0">5</div>
          <div>
            <h4 class="text-xl font-heading text-white">Ember Browser</h4>
            <p class="text-muted-text">Secure, lightweight, no trackers, no BS and no limits to customization</p>
          </div>
        </div>

        <div class="flex items-center gap-6 bg-base p-6 rounded-lg border border-border reveal-left stagger-1">
          <div class="w-16 h-16 bg-cinder-mid flex items-center justify-center rounded text-white font-heading text-xl flex-shrink-0">6</div>
          <div>
            <h4 class="text-xl font-heading text-white">CPAC Trust DB</h4>
            <p class="text-muted-text">Crowdsourced intelligence for CPAC's security system</p>
          </div>
        </div>

        <div class="flex items-center gap-6 bg-base p-6 rounded-lg border border-border reveal-left stagger-2">
          <div class="w-16 h-16 bg-elevated flex items-center justify-center rounded text-muted-text font-heading text-xl flex-shrink-0">2</div>
          <div>
            <h4 class="text-xl font-heading text-white">Future Projects</h4>
            <p class="text-muted-text">Expanding the ecosystem with utility applications.</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</MainLayout>
