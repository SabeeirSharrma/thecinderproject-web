---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Home">
  <!-- Hero Section -->
  <section class="relative min-h-[70vh] flex flex-col justify-center items-center text-center px-4 overflow-hidden">
    <!-- Animated ember glow background -->
    <div class="absolute inset-0 z-0 opacity-20 pointer-events-none ember-glow-bg"></div>
    
    <!-- Floating ember particles -->
    <div class="absolute bottom-0 inset-x-0 h-32 z-0 pointer-events-none">
      <span class="ember-particle"></span>
      <span class="ember-particle"></span>
      <span class="ember-particle"></span>
      <span class="ember-particle"></span>
      <span class="ember-particle"></span>
    </div>

    <div class="z-10 max-w-4xl">
      <h1 class="text-5xl md:text-7xl font-heading mb-6 tracking-wider anim-slide-up">
        <span class="text-white">The </span><span class="text-shimmer">Cinder</span><span class="text-white"> Project</span>
      </h1>
      <p class="text-xl md:text-2xl text-muted-text mb-10 max-w-2xl mx-auto anim-slide-up delay-2">
        Building open software that lasts.
      </p>
      <div class="flex flex-col sm:flex-row justify-center gap-4 anim-slide-up delay-3">
        <a href="#projects" class="btn-primary">View Projects</a>
        <a href="#docs" class="btn-secondary">Read Docs</a>
      </div>
    </div>
  </section>

  <!-- Mission Section -->
  <section class="py-20 bg-surface border-y border-border">
    <div class="container mx-auto px-4 text-center max-w-3xl reveal">
      <h2 class="text-3xl font-heading text-white mb-6 uppercase tracking-widest heading-line">Our Mission</h2>
      <p class="text-lg text-muted-text leading-relaxed">
        The Cinder Project develops and maintains open-source software with a focus on stability, transparency, and long-term maintainability.
      </p>
    </div>
  </section>

  <!-- Featured Projects -->
  <section id="projects" class="py-24 container mx-auto px-4">
    <h2 class="text-4xl font-heading text-white mb-12 text-center uppercase tracking-widest reveal heading-line">Featured Projects</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-5xl mx-auto">
      
      <!-- CPAC Card -->
      <div class="card group relative overflow-hidden reveal stagger-1">
        <div class="absolute top-0 right-0 w-32 h-32 bg-deep-red rounded-bl-full opacity-10 group-hover:opacity-30 transition-opacity duration-500"></div>
        <h3 class="text-2xl font-heading text-white mb-4">CPAC</h3>
        <p class="text-muted-text mb-8">
          Package management and deployment. A tool built for seamless integration and robust dependency resolution.
        </p>
        <div class="flex gap-4">
          <a href="/cpac" class="text-ember-light hover:text-ember-glow font-bold uppercase tracking-wider text-sm transition-colors">Cpac Page</a>
          <a href="/cpac/docs" class="text-muted-text hover:text-white uppercase tracking-wider text-sm transition-colors">Docs</a>
        </div>
      </div>

      <!-- CinderOS Card -->
      <div class="card group relative overflow-hidden reveal stagger-2">
        <div class="absolute top-0 right-0 w-32 h-32 bg-ember-core rounded-bl-full opacity-10 group-hover:opacity-30 transition-opacity duration-500"></div>
        <h3 class="text-2xl font-heading text-white mb-4">CinderOS</h3>
        <p class="text-muted-text mb-8">
          A Cinder Project operating system. Lightweight, modular, and designed from the ground up for stability and performance.
        </p>
        <div class="flex gap-4">
          <a href="/cinderos" class="text-ember-light hover:text-ember-glow font-bold uppercase tracking-wider text-sm transition-colors">CinderOS Page</a>
          <a href="/cinderos/docs" class="text-muted-text hover:text-white uppercase tracking-wider text-sm transition-colors">Docs</a>
        </div>
      </div>

    </div>
  </section>

  <!-- Roadmap Preview -->
  <section class="py-20 bg-surface border-y border-border">
    <div class="container mx-auto px-4 max-w-4xl">
      <h2 class="text-3xl font-heading text-white mb-10 text-center uppercase tracking-widest reveal heading-line">Roadmap Preview</h2>
      
      <div class="space-y-6">
        <div class="flex items-center gap-6 bg-base p-6 rounded-lg border border-border reveal-left stagger-1">
          <div class="w-16 h-16 bg-cinder-mid flex items-center justify-center rounded text-white font-heading text-xl flex-shrink-0">1</div>
          <div>
            <h4 class="text-xl font-heading text-white">CPAC</h4>
            <p class="text-muted-text">Initial stable release and ecosystem integration.</p>
          </div>
        </div>
        
        <div class="flex items-center gap-6 bg-base p-6 rounded-lg border border-border reveal-left stagger-2">
          <div class="w-16 h-16 bg-ember-core flex items-center justify-center rounded text-white font-heading text-xl flex-shrink-0">2</div>
          <div>
            <h4 class="text-xl font-heading text-white">CinderOS</h4>
            <p class="text-muted-text">Core architecture prototyping and kernel selection.</p>
          </div>
        </div>
        
        <div class="flex items-center gap-6 bg-base p-6 rounded-lg border border-border opacity-60 reveal-left stagger-3">
          <div class="w-16 h-16 bg-elevated flex items-center justify-center rounded text-muted-text font-heading text-xl flex-shrink-0">3</div>
          <div>
            <h4 class="text-xl font-heading text-white">Future Projects</h4>
            <p class="text-muted-text">Expanding the ecosystem with utility applications.</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</MainLayout>
